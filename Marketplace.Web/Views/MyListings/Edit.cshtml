@model Marketplace.Web.Models.MyListings.MyListingFormVm
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Edit Listing";
    var categories = ViewBag.Categories as List<SelectListItem> ?? new();
    var subCategories = ViewBag.SubCategories as List<SelectListItem> ?? new();
    var cities = ViewBag.Cities as List<SelectListItem> ?? new();
}

<div class="container py-4" style="max-width:800px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Edit Listing</h1>
        <div class="d-flex gap-2">
            <a asp-controller="MyListingPhotos" asp-action="Index" asp-route-listingId="@Model.Id" class="btn btn-outline-secondary btn-sm">Photos</a>
            <a asp-controller="MyListingRental" asp-action="Edit" asp-route-listingId="@Model.Id" class="btn btn-outline-secondary btn-sm">Rental</a>
            <a asp-controller="MyListingVacancies" asp-action="Index" asp-route-listingId="@Model.Id" class="btn btn-outline-secondary btn-sm">Vacancies</a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back</a>
        </div>
    </div>

    @if (TempData["Success"] is string msg)
    {
        <div class="alert alert-success">@msg</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <form method="post" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none;"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" class="form-control app-input" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label fw-semibold"></label>
                        <select asp-for="CategoryId" class="form-select app-select">
                            <option value="">Select category</option>
                            @foreach (var item in categories)
                            {
                                <option value="@item.Value" selected="@(Model.CategoryId.ToString() == item.Value)">@item.Text</option>
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SubCategoryId" class="form-label fw-semibold"></label>
                        <select asp-for="SubCategoryId" class="form-select app-select">
                            <option value="">Select subcategory</option>
                            @foreach (var item in subCategories)
                            {
                                <option value="@item.Value" selected="@(Model.SubCategoryId.ToString() == item.Value)">@item.Text</option>
                            }
                        </select>
                        <span asp-validation-for="SubCategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CityId" class="form-label fw-semibold"></label>
                        <select asp-for="CityId" class="form-select app-select">
                            <option value="">Select city</option>
                            @foreach (var item in cities)
                            {
                                <option value="@item.Value" selected="@(Model.CityId.ToString() == item.Value)">@item.Text</option>
                            }
                        </select>
                        <span asp-validation-for="CityId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label fw-semibold"></label>
                        <input asp-for="Phone" class="form-control app-input" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control app-input" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Website" class="form-label fw-semibold"></label>
                        <input asp-for="Website" class="form-control app-input" />
                    </div>

                    <div class="col-12">
                        <label asp-for="Address" class="form-label fw-semibold"></label>
                        <input asp-for="Address" class="form-control app-input" />
                    </div>

                    <div class="col-12">
                        <label asp-for="ShortDescription" class="form-label fw-semibold"></label>
                        <input asp-for="ShortDescription" class="form-control app-input" maxlength="500" />
                        <span asp-validation-for="ShortDescription" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control app-input" rows="5"></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
