@model Marketplace.Web.Models.MyListings.MyListingIndexVm
@using Marketplace.Modules.Listings.Domain.Enums.Listing
@{
    ViewData["Title"] = "My Listings";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0">My Listings</h1>
            <p class="text-muted mb-0">@Model.TotalCount listing(s)</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">+ New Listing</a>
    </div>

    @if (TempData["Success"] is string msg)
    {
        <div class="alert alert-success">@msg</div>
    }

    @if (Model.Items.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var item in Model.Items)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrWhiteSpace(item.PrimaryImageUrl))
                        {
                            <img src="@item.PrimaryImageUrl" class="card-img-top" style="height:180px;object-fit:cover;" alt="@item.Title" />
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:180px;">
                                <span class="text-muted">No photo</span>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@item.Title</h5>
                            <p class="card-text text-muted small">@item.CategoryName &bull; @item.CityName</p>
                            @if (!string.IsNullOrWhiteSpace(item.ShortDescription))
                            {
                                <p class="card-text small">@item.ShortDescription</p>
                            }
                            <span class="badge @(item.Status == ListingStatus.Active ? "bg-success" : item.Status == ListingStatus.Draft ? "bg-secondary" : "bg-warning text-dark")">
                                @item.Status
                            </span>
                        </div>
                        <div class="card-footer bg-transparent d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary flex-fill">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this listing?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <p class="text-muted mb-3">You have no listings yet.</p>
            <a asp-action="Create" class="btn btn-primary">Create your first listing</a>
        </div>
    }
</div>
