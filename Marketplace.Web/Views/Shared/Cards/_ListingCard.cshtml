@model Marketplace.Web.Models.Listings.ListingCardVm

<article class="catalog-card listing-card">
    <div>
        <div class="catalog-card__top">
            <div class="catalog-card__accent">★</div>

            @* @if (Model.Rating.HasValue)
            {
                <div class="listing-card__score">
                    <span class="listing-card__score-value">@Model.Rating.Value.ToString("0.0")</span>
                </div>
            } *@

            <div class="listing-card__score">
                    <span class="listing-card__score-value">@Model.Rating.ToString("0.0")</span>
                </div>
        </div>

        <h3 class="catalog-card__title">
            <a href="@Model.Url">@Model.Title</a>
        </h3>

        <div class="catalog-card__meta">
            <span class="catalog-card__chip">@Model.SubcategoryName</span>

            @if (Model.ReviewsCount > 0)
            {
                <span class="catalog-card__count">@Model.ReviewsCount відгуків</span>
            }
            else
            {
                <span class="catalog-card__count">Новий профіль</span>
            }
        </div>

        <p class="catalog-card__description">
            Перегляньте деталі профілю, рейтинг, відгуки та більше інформації про виконавця.
        </p>
    </div>

    <div class="catalog-card__footer">
        <a href="@Model.Url" class="catalog-card__link">Детальніше</a>
    </div>
</article>