@using Marketplace.Web.Utils
@{
    var currentCulture = CultureHelper.Current();
    var path = Context.Request.Path.Value ?? "/";
    var query = Context.Request.QueryString.Value ?? string.Empty;

    var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries).ToList();

    string BuildSwitchUrl(string targetCulture)
    {
        var copy = segments.ToList();

        if (copy.Count > 0 && (copy[0] == "uk" || copy[0] == "ru"))
        {
            copy[0] = targetCulture;
        }
        else
        {
            copy.Insert(0, targetCulture);
        }

        return "/" + string.Join("/", copy) + query;
    }
}

<div class="language-switcher language-switcher-sm">
    <a href="@BuildSwitchUrl("uk")"
       class="btn @(currentCulture == "uk" ? "btn-app" : "btn-app-outline") btn-sm">
        UK
    </a>

    <a href="@BuildSwitchUrl("ru")"
       class="btn @(currentCulture == "ru" ? "btn-app" : "btn-app-outline") btn-sm">
        RU
    </a>
</div>