@using Marketplace.Web.Utils
@{
    var culture = CultureHelper.Current();
}

<footer class="site-footer">
    <div class="container app-container">
        <div class="footer-inner">
            <div>
                <div class="footer-brand">Marketplace</div>
                <div class="footer-text">SEO-oriented service catalog with a clean and mobile-friendly UI.</div>
            </div>

            <div class="footer-links">
                <a href="/@culture/for-business">@(culture == "uk" ? "Для бізнесу" : "Для бизнеса")</a>
                <a href="/@culture/blog">@(culture == "uk" ? "Блог" : "Блог")</a>
                <a href="/@culture/catalog">@(culture == "uk" ? "Каталог" : "Каталог")</a>
                <a href="/@culture/support">@(culture == "uk" ? "Підтримка" : "Поддержка")</a>
                <a href="/@culture/privacy">@(culture == "uk" ? "Конфіденційність" : "Конфиденциальность")</a>
            </div>
        </div>
    </div>
</footer>