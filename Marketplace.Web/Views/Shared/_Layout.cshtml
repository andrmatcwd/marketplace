@using System.Globalization
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

    <partial name="~/Views/Shared/Layout/_SeoMeta.cshtml" />
    @await RenderSectionAsync("StructuredData", required: false)

    <link rel="icon" type="image/x-icon" href="~/img/favicons/favicon.ico" />
    <link rel="apple-touch-icon" href="~/img/favicons/apple-touch-icon.png" />
    <link rel="manifest" href="~/img/favicons/site.webmanifest" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/utilities.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/components/topnav.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/buttons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/breadcrumbs.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/hero.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/section.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/cookie-consent.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="~/css/components/select2-theme.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="app-body">
    <partial name="~/Views/Shared/Layout/_Header.cshtml" />

    <div class="app-shell">
        <main class="app-main">
            <div class="container app-container">
                @RenderBody()
            </div>
        </main>

        <partial name="~/Views/Shared/Layout/_Footer.cshtml" />
        <partial name="~/Views/Shared/Layout/_MobileBottomBar.cshtml" />
    </div>

    <partial name="~/Views/Shared/Cookie/_CookieConsent.cshtml" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/core/select2-init.js" asp-append-version="true"></script>
    <script src="~/js/cookie-consent.js" asp-append-version="true"></script>
    <script src="~/js/preferred-city.js" asp-append-version="true"></script>
    
    <script src="~/js/core/toggle-collapsible.js" asp-append-version="true"></script>
    <script src="~/js/core/location-context.js" asp-append-version="true"></script>
    <script src="~/js/core/city-bootstrap.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>