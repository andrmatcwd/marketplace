@using System.Globalization
@using Marketplace.Web.Seo
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @{
        var seo = ViewData["Seo"] as PageSeoData;
    }

    <title>@(seo?.Title ?? "Marketplace")</title>

    @if (!string.IsNullOrWhiteSpace(seo?.Description))
    {
        <meta name="description" content="@seo.Description" />
    }

    @if (!string.IsNullOrWhiteSpace(seo?.CanonicalUrl))
    {
        <link rel="canonical" href="@seo.CanonicalUrl" />
    }

    @if (!string.IsNullOrWhiteSpace(seo?.Robots))
    {
        <meta name="robots" content="@seo.Robots" />
    }

    @if (seo?.JsonLdBlocks != null)
    {
        foreach (var block in seo.JsonLdBlocks)
        {
            <script type="application/ld+json">
                @Html.Raw(block)
            </script>
        }
    }

    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Marketplace.Web.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Marketplace.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Listings" asp-action="Index">Services</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Listings" asp-action="Index">
                                Admin
                            </a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container d-flex justify-content-between align-items-center">

            <!-- Left side -->
            <div>
                &copy; 2026 - Marketplace.Web -
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>

            <!-- Right side 🌍 Language switcher -->
            <form asp-controller="Culture" asp-action="SetLanguage" method="post" class="d-flex">
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                <button type="submit" name="culture" value="en" class="btn btn-sm btn-outline-secondary">
                    EN
                </button>
                <button type="submit" name="culture" value="uk" class="btn btn-sm btn-outline-secondary ms-1">
                    UK
                </button>
            </form>

        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
