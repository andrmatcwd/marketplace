@model Marketplace.Web.Models.Catalog.CatalogIndexPageVm

<section class="catalog-hero">
    <div class="catalog-hero__inner">
        <span class="catalog-hero__badge">Каталог послуг</span>

        <h1 class="catalog-hero__title">@Model.H1</h1>

        @if (!string.IsNullOrWhiteSpace(Model.IntroText))
        {
            <p class="catalog-hero__text">@Model.IntroText</p>
        }

        <div class="catalog-stats">
            <div class="catalog-stat">
                <span class="catalog-stat__value">@Model.Cities.Count</span>
                <span class="catalog-stat__label">Міст</span>
            </div>

            <div class="catalog-stat">
                <span class="catalog-stat__value">@Model.PopularCategories.Count</span>
                <span class="catalog-stat__label">Популярних категорій</span>
            </div>
        </div>
    </div>
</section>