@model Marketplace.Web.Models.UI.SectionHeaderVm

<div class="section-header">
    <div class="section-header__content">
        @if (!string.IsNullOrWhiteSpace(Model.Eyebrow))
        {
            <div class="section-header__eyebrow">@Model.Eyebrow</div>
        }

        <h2 class="section-header__title">@Model.Title</h2>

        @if (!string.IsNullOrWhiteSpace(Model.Text))
        {
            <p class="section-header__text">@Model.Text</p>
        }
    </div>
</div>