@model Marketplace.Web.Models.Common.BaseFilter

<section class="catalog-filters">
    <form method="get" class="catalog-filters__form">
        <div class="catalog-filters__group catalog-filters__group--search">
            <label class="catalog-filters__label" for="searchTerm">Пошук</label>
            <input id="searchTerm"
                   name="SearchTerm"
                   value="@Model.SearchTerm"
                   class="catalog-input"
                   type="text"
                   placeholder="Пошук послуги або компанії" />
        </div>

        <div class="catalog-filters__group catalog-filters__group--small">
            <label class="catalog-filters__label" for="ratingFrom">Рейтинг від</label>
            <select id="ratingFrom" name="RatingFrom" class="catalog-select">
                <option value="">Будь-який</option>
                <option value="4" selected="@(Model.RatingFrom == 4)">4.0+</option>
                <option value="4.5" selected="@(Model.RatingFrom == 4.5)">4.5+</option>
            </select>
        </div>

        <div class="catalog-filters__group catalog-filters__group--small">
            <label class="catalog-filters__label" for="sortBy">Сортування</label>
            <select id="sortBy" name="SortBy" class="catalog-select">
                <option value="newest" selected="@(Model.SortBy == "newest")">Спочатку нові</option>
                <option value="rating" selected="@(Model.SortBy == "rating")">За рейтингом</option>
                <option value="popular" selected="@(Model.SortBy == "popular")">За популярністю</option>
            </select>
        </div>

        <div class="catalog-filters__actions">
            <button type="submit" class="catalog-btn catalog-btn--primary">Застосувати</button>
            <a href="?" class="catalog-btn catalog-btn--secondary">Скинути</a>
        </div>
    </form>
</section>