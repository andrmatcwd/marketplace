@model Marketplace.Web.Models.Vacancies.VacancyCardVm

<article class="app-card vacancy-card">
    <div class="vacancy-card-body">
        <div class="vacancy-card-header">
            <h3 class="vacancy-card-title">@Model.Title</h3>

            <div class="vacancy-card-meta">
                @if (!string.IsNullOrWhiteSpace(Model.EmploymentType))
                {
                    <span class="vacancy-card-badge">@Model.EmploymentType</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.CityName))
                {
                    <span class="vacancy-card-meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                        @Model.CityName
                    </span>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="vacancy-card-description">@Model.Description</p>
        }

        <div class="vacancy-card-details">
            @if (!string.IsNullOrWhiteSpace(Model.SalaryText))
            {
                <span class="vacancy-card-detail">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <line x1="12" y1="1" x2="12" y2="23"/>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                    </svg>
                    @Model.SalaryText
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.LocationText))
            {
                <span class="vacancy-card-detail">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    @Model.LocationText
                </span>
            }
        </div>

        <div class="vacancy-card-footer">
            <div class="vacancy-card-listing">
                <span class="vacancy-card-listing-label">Company:</span>
                <a href="@Model.ListingUrl" class="vacancy-card-listing-name">@Model.ListingTitle</a>
                <span class="vacancy-card-listing-category">@Model.SubCategoryName</span>
            </div>
            <a href="@Model.ListingUrl" class="btn btn-app-outline btn-sm">
                View listing
            </a>
        </div>
    </div>
</article>
