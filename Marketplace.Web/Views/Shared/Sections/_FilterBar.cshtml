@model Marketplace.Web.Models.Catalog.CatalogFilterVm

<form method="get" class="filter-bar app-card">
    <div class="filter-bar-inner">
        <div class="filter-bar-group filter-bar-group-grow">
            <label class="filter-label" for="search">Search</label>
            <input id="search"
                   name="search"
                   value="@Model.Search"
                   type="text"
                   class="form-control app-input"
                   placeholder="Service title or keyword" />
        </div>

        @if (Model.Cities != null && Model.Cities.Any())
        {
            <div class="filter-bar-group">
                <label class="filter-label" for="city">City</label>
                <select id="city" name="city" class="form-select app-select">
                    <option value="">All cities</option>
                    @foreach (var option in Model.Cities)
                    {
                        if (string.Equals(option.Value, Model.City, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@option.Value" selected>@option.Text</option>
                        }
                        else
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    }
                </select>
            </div>
        }

        @if (Model.Categories != null && Model.Categories.Any())
        {
            <div class="filter-bar-group">
                <label class="filter-label" for="category">Category</label>
                <select id="category" name="category" class="form-select app-select">
                    <option value="">All categories</option>
                    @foreach (var option in Model.Categories)
                    {
                        if (string.Equals(option.Value, Model.Category, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@option.Value" selected>@option.Text</option>
                        }
                        else
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    }
                </select>
            </div>
        }

        @if (Model.Categories != null && Model.Categories.Any())
        {
            <div class="filter-bar-group">
                <label class="filter-label" for="category">SubCategory</label>
                <select id="category" name="category" class="form-select app-select">
                    <option value="">All categories</option>
                    @foreach (var option in Model.Categories)
                    {
                        if (string.Equals(option.Value, Model.Category, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@option.Value" selected>@option.Text</option>
                        }
                        else
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    }
                </select>
            </div>
        }

        <div class="filter-bar-group">
            <label class="filter-label" for="sort">Sort</label>
            <select id="sort" name="sort" class="form-select app-select">
                <option value="">Default</option>
                @foreach (var option in Model.SortOptions)
                {
                    if (string.Equals(option.Value, Model.Sort, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@option.Value" selected>@option.Text</option>
                    }
                    else
                    {
                        <option value="@option.Value">@option.Text</option>
                    }
                }
            </select>
        </div>

        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="pageSize" value="@Model.PageSize" />

        <div class="filter-bar-actions">
            <button type="submit" class="btn btn-app">Apply</button>
            <a href="@Model.ResetUrl" class="btn btn-app-outline">Reset</a>
        </div>
    </div>
</form>