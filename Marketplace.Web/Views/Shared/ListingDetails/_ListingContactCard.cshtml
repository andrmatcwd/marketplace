@model Marketplace.Web.Models.Listings.ListingDetailsPageVm

@if (Model.Contact.HasAny)
{
    <section class="app-card listing-contact-card">
        <div class="listing-contact-body">
            <h2 class="section-title">Контакти</h2>

            @if (!string.IsNullOrWhiteSpace(Model.Contact.ContactName))
            {
                <div class="contact-row">
                    <span class="contact-icon">👤</span>
                    <strong>@Model.Contact.ContactName</strong>
                </div>
            }

            @if (Model.Contact.HasPhone)
            {
                <div class="contact-row">
                    <span class="contact-icon">📞</span>
                    <a href="tel:@Model.Contact.Phone"
                    class="listing-phone-link"
                    data-phone="@Model.Contact.Phone"
                    data-listing-id="@Model.Id"
                    data-listing-title="@Model.Title">
                        @Model.Contact.Phone
                    </a>
                </div>
            }

            @if (Model.Contact.HasEmail)
            {
                <div class="contact-row">
                    <span class="contact-icon">✉️</span>
                    <a href="mailto:@Model.Contact.Email">@Model.Contact.Email</a>
                </div>
            }

            @if (Model.Contact.HasWebsite)
            {
                <div class="contact-row">
                    <span class="contact-icon">🌐</span>
                    <a href="@Model.Contact.Website" rel="nofollow noopener" target="_blank">
                        @Model.Contact.Website
                    </a>
                </div>
            }
        </div>
    </section>
}