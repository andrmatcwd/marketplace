@model Marketplace.Web.Models.Listings.ListingContactVm

@if (Model.HasAny)
{
    <section class="app-card listing-contact-card">
        <div class="listing-contact-body">
            <h2 class="section-title">Contacts</h2>

            @if (!string.IsNullOrWhiteSpace(Model.ContactName))
            {
                <div class="contact-row">
                    <strong>@Model.ContactName</strong>
                </div>
            }

            @if (Model.HasPhone)
            {
                <div class="contact-row">
                    <a href="tel:@Model.Phone">@Model.Phone</a>
                </div>
            }

            @if (Model.HasEmail)
            {
                <div class="contact-row">
                    <a href="mailto:@Model.Email">@Model.Email</a>
                </div>
            }

            @if (Model.HasWebsite)
            {
                <div class="contact-row">
                    <a href="@Model.Website" rel="nofollow noopener" target="_blank">@Model.Website</a>
                </div>
            }
        </div>
    </section>
}