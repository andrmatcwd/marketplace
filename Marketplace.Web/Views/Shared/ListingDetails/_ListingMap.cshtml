@model Marketplace.Web.Models.Listings.ListingDetailsPageVm

@{
    ViewData["Title"] = Model.Title;
}

@if (Model.HasCoordinates)
{
    <section class="app-card listing-map-card">
        <div class="listing-map-body">
            <h2 class="section-title">Location</h2>

            @if (!string.IsNullOrWhiteSpace(Model.Address))
            {
                <p class="section-description">@Model.Address</p>
            }

            <div id="listingMap"
                 class="listing-map-canvas"
                 data-lat="@Model.Latitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                 data-lng="@Model.Longitude!.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                 data-title="@Model.Title"
                 data-address="@Model.Address">
            </div>
        </div>
    </section>
}