@model IReadOnlyCollection<Marketplace.Web.Models.Listings.ListingReviewVm>

@if (Model != null && Model.Any())
{
    var previewCount = 3;
    var hasToggle = Model.Count > previewCount;

    <section class="app-card listing-reviews">
        <div class="listing-reviews-body">
            <div class="listing-reviews-header">
                <h2 class="section-title">Відгуки</h2>
            </div>

            <div class="listing-reviews-collapsible" data-collapsible>

                <!-- preview -->
                <div class="listing-reviews-list">
                    @foreach (var review in Model.Take(previewCount))
                    {
                        <partial name="~/Views/Shared/ListingDetails/_ListingReviewCard.cshtml"
                                 model="review" />
                    }
                </div>

                @if (hasToggle)
                {
                    <!-- extra -->
                    <div class="listing-reviews-extra" data-collapsible-content>
                        <div class="listing-reviews-list listing-reviews-list-extra">
                            @foreach (var review in Model.Skip(previewCount))
                            {
                                <partial name="~/Views/Shared/ListingDetails/_ListingReviewCard.cshtml"
                                         model="review" />
                            }
                        </div>
                    </div>

                    <!-- button -->
                    <button type="button"
                            class="listing-reviews-toggle btn btn-app-outline btn-sm"
                            data-collapsible-toggle
                            data-expand-text="Показати всі"
                            data-collapse-text="Згорнути">
                        Показати всі
                    </button>
                }
            </div>
        </div>
    </section>
}