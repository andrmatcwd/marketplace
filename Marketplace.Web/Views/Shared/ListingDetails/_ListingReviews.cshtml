@model Marketplace.Web.Models.Listings.ListingDetailsPageVm

@{
    var hasReviews = Model.Reviews != null && Model.Reviews.Any();
    var hasToggle = hasReviews && Model.Reviews.Count > 3;
    var reviewsWrapperClass = hasToggle
        ? "listing-reviews-list-wrapper has-toggle"
        : "listing-reviews-list-wrapper";
    var reviewsListClass = hasToggle
        ? "listing-reviews-list listing-reviews-list-collapsed"
        : "listing-reviews-list";
}

<section class="app-card listing-reviews-card">
    <div class="listing-reviews-body">
        <h2 class="section-title">Відгуки</h2>

        @if (TempData["ReviewSuccess"] is string successMessage)
        {
            <div class="alert alert-success mt-3">@successMessage</div>
        }

        @if (TempData["ReviewError"] is string errorMessage)
        {
            <div class="alert alert-danger mt-3">@errorMessage</div>
        }

        @if (hasReviews)
        {
            <div class="@reviewsWrapperClass" data-reviews-wrapper>
                <div class="@reviewsListClass" data-reviews-list>
                    @foreach (var review in Model.Reviews)
                    {
                        <article class="listing-review-item">
                            <div class="listing-review-head">
                                <strong>@review.AuthorName</strong>

                                @if (review.Rating > 0)
                                {
                                    <span>★ @review.RatingFormatted</span>
                                }
                            </div>

                            @if (review.HasText)
                            {
                                <p>@review.Text</p>
                            }
                        </article>
                    }
                </div>

                @if (hasToggle)
                {
                    <div class="listing-reviews-actions">
                        <button type="button"
                                class="btn btn-app-outline btn-sm"
                                data-reviews-toggle>
                            Показати всі
                        </button>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="section-description mb-4">Ще немає відгуків. Будьте першим, хто залишить відгук.</p>
        }

