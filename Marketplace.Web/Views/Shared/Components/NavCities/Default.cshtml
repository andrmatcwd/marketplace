@model IReadOnlyCollection<Marketplace.Web.Models.Shared.NavCityOptionVm>
@using Marketplace.Web.Utils

@{
    var culture = CultureHelper.Current();
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var segments = currentPath.Split('/', StringSplitOptions.RemoveEmptyEntries);

    var currentCitySlug = segments.Length >= 2 ? segments[1] : null;

    var selectedCity = Model.FirstOrDefault(x =>
        string.Equals(x.Slug, currentCitySlug, StringComparison.OrdinalIgnoreCase));
}

<div class="dropdown nav-city-dropdown">
    <button class="btn btn-app-outline nav-city-btn dropdown-toggle"
            type="button"
            data-bs-toggle="dropdown"
            aria-expanded="false">
        @(selectedCity?.Name ?? "Місто")
    </button>

    <ul class="dropdown-menu nav-city-menu">
        @foreach (var city in Model)
        {
            <li>
                <a class="dropdown-item @(city.Slug == currentCitySlug ? "active" : "")"
                   href="@city.Url">
                    @city.Name
                </a>
            </li>
        }
    </ul>
</div>