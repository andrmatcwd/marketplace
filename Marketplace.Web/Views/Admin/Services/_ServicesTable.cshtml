@model Marketplace.Web.Models.Admin.Services.AdminServicesPageViewModel

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Image</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>City</th>
                        <th>Price</th>
                        <th>Rating</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                No services found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>
                                    <img src="@item.ImageUrl"
                                         alt="@item.Title"
                                         style="width:72px;height:56px;object-fit:cover;border-radius:8px;" />
                                </td>
                                <td>@item.Title</td>
                                <td>@item.Category</td>
                                <td>@item.City</td>
                                <td>@item.Price @item.Currency</td>
                                <td>@item.Rating</td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-area=""
                                           asp-controller="ServicesAdmin"
                                           asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-secondary">
                                            Edit
                                        </a>

                                        <form asp-area=""
                                              asp-controller="ServicesAdmin"
                                              asp-action="Delete"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              onsubmit="return confirm('Delete this service?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="~/Views/Admin/Services/_Pagination.cshtml" model="Model" />
</div>