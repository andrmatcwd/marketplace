@model Marketplace.Web.Models.Admin.Services.AdminServicesPageViewModel

<div class="mb-4">
    <h1 class="h3 mb-1">Admin Panel</h1>
    <p class="text-muted mb-0">Manage services and navigate to other resources.</p>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-6 col-md-4 col-xl-2">
                <a asp-area=""
                   asp-controller="ServicesAdmin"
                   asp-action="Index"
                   class="btn btn-primary w-100">
                    Services
                </a>
            </div>

            <div class="col-6 col-md-4 col-xl-2">
                <a asp-area=""
                   asp-controller="CategoriesAdmin"
                   asp-action="Index"
                   class="btn btn-outline-secondary w-100">
                    Categories
                </a>
            </div>

            <div class="col-6 col-md-4 col-xl-2">
                <a asp-area=""
                   asp-controller="Users"
                   asp-action="Index"
                   class="btn btn-outline-secondary w-100">
                    Users
                </a>
            </div>

            <div class="col-6 col-md-4 col-xl-2">
                <a asp-area=""
                   asp-controller="Reviews"
                   asp-action="Index"
                   class="btn btn-outline-secondary w-100">
                    Reviews
                </a>
            </div>

            <div class="col-6 col-md-4 col-xl-2">
                <a asp-area=""
                   asp-controller="Bookings"
                   asp-action="Index"
                   class="btn btn-outline-secondary w-100">
                    Bookings
                </a>
            </div>

            <div class="col-6 col-md-4 col-xl-2">
                <a asp-area=""
                   asp-controller="Settings"
                   asp-action="Index"
                   class="btn btn-outline-secondary w-100">
                    Settings
                </a>
            </div>
        </div>
    </div>
</div>