@model Marketplace.Web.Models.Services.ServiceItemViewModel

<div class="col-sm-6 col-xl-4">
    <div class="card h-100 border-0 shadow-sm service-card">
        <div class="service-card-image"></div>

        <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="badge text-bg-light border text-capitalize">@Model.Category</span>
                <span class="text-muted small">@Model.Rating.ToString("0.0") ★</span>
            </div>

            <h5 class="card-title mb-2">@Model.Title</h5>

            <p class="card-text text-muted mb-3">@Model.Description</p>

            <div class="mt-auto">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="fw-semibold fs-5">@Model.Price @Model.Currency</span>
                    <span class="text-muted small">@Model.City</span>
                </div>

                <div class="small text-muted mb-3">
                    @(Model.IsOnline ? "Online" : "")@(Model.IsOnline && Model.IsOffline ? " / " : "")@(Model.IsOffline ? "Offline" : "")
                </div>

                <a href="#" class="btn btn-primary w-100">View details</a>
            </div>
        </div>
    </div>
</div>