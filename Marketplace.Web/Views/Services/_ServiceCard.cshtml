@model int

<div class="col-sm-6 col-xl-4">
    <div class="card h-100 border-0 shadow-sm service-card">
        <div class="service-card-image"></div>

        <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <span class="badge text-bg-light border">Category</span>
                <span class="text-muted small">4.8 ★</span>
            </div>

            <h5 class="card-title mb-2">Service @Model</h5>

            <p class="card-text text-muted mb-3">
                Professional service description goes here. Add short summary for the listing.
            </p>

            <div class="mt-auto">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="fw-semibold fs-5">$50</span>
                    <span class="text-muted small">Kyiv</span>
                </div>

                <a href="#" class="btn btn-primary w-100">View details</a>
            </div>
        </div>
    </div>
</div>