@{
    ViewData["Title"] = "Services";
}

@section Styles {
    <link rel="stylesheet" href="~/css/services.css" asp-append-version="true" />
}

<div class="services-page container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-1">Services</h1>
            <p class="text-muted mb-0">Browse services and use filters to refine results.</p>
        </div>

        <div class="d-flex align-items-center gap-2">
            <!-- Desktop toggle -->
            <button type="button"
                    id="desktopFiltersToggle"
                    class="btn btn-outline-secondary d-none d-lg-inline-flex align-items-center">
                <span class="services-toggle-text">Hide filters</span>
            </button>

            <!-- Mobile toggle -->
            <button class="btn btn-primary d-lg-none"
                    type="button"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#mobileFiltersOffcanvas"
                    aria-controls="mobileFiltersOffcanvas">
                Filters
            </button>
        </div>
    </div>

    <div class="services-layout d-flex gap-4 align-items-start">
        <!-- Desktop sidebar -->
        <aside id="desktopFiltersSidebar" class="services-filters-sidebar d-none d-lg-block">
            <div class="card border-0 shadow-sm services-filters-card">
                <div class="card-body p-0">
                    @await Html.PartialAsync("_ServiceFilters")
                </div>
            </div>
        </aside>

        <!-- Content -->
        <section class="services-content flex-grow-1">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-6 col-xl-3">
                            <label class="form-label">Search</label>
                            <input type="text" class="form-control" placeholder="Search services..." />
                        </div>

                        <div class="col-md-6 col-xl-3">
                            <label class="form-label">Category</label>
                            <select class="form-select">
                                <option selected>All categories</option>
                                <option>Beauty</option>
                                <option>Repair</option>
                                <option>Education</option>
                                <option>Cleaning</option>
                            </select>
                        </div>

                        <div class="col-md-6 col-xl-3">
                            <label class="form-label">Sort by</label>
                            <select class="form-select">
                                <option selected>Newest</option>
                                <option>Price: Low to High</option>
                                <option>Price: High to Low</option>
                                <option>Top Rated</option>
                            </select>
                        </div>

                        <div class="col-md-6 col-xl-3">
                            <label class="form-label">View</label>
                            <div class="d-grid">
                                <button class="btn btn-outline-secondary" type="button">12 results found</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                @for (int i = 1; i <= 9; i++)
                {
                    <div class="col-sm-6 col-xl-4">
                        <div class="card h-100 border-0 shadow-sm service-card">
                            <div class="service-card-image"></div>

                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="badge text-bg-light border">Category</span>
                                    <span class="text-muted small">4.8 ★</span>
                                </div>

                                <h5 class="card-title mb-2">Service @i</h5>

                                <p class="card-text text-muted mb-3">
                                    Professional service description goes here. Add short summary for the listing.
                                </p>

                                <div class="mt-auto">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="fw-semibold fs-5">$50</span>
                                        <span class="text-muted small">Kyiv</span>
                                    </div>

                                    <a href="#" class="btn btn-primary w-100">View details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <nav class="mt-4" aria-label="Services pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item"><a class="page-link" href="#">Next</a></li>
                </ul>
            </nav>
        </section>
    </div>
</div>

<!-- Mobile Offcanvas -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="mobileFiltersOffcanvas" aria-labelledby="mobileFiltersOffcanvasLabel">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title" id="mobileFiltersOffcanvasLabel">Filters</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>

    <div class="offcanvas-body p-0">
        @await Html.PartialAsync("_ServiceFilters")
    </div>
</div>

@section Scripts {
    <script src="~/js/services.js" asp-append-version="true"></script>
}