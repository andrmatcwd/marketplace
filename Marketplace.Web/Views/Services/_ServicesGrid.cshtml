<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-6 col-xl-3">
                <label class="form-label">Search</label>
                <input type="text" class="form-control" placeholder="Search services..." />
            </div>

            <div class="col-md-6 col-xl-3">
                <label class="form-label">Category</label>
                <select class="form-select">
                    <option selected>All categories</option>
                    <option>Beauty</option>
                    <option>Repair</option>
                    <option>Education</option>
                    <option>Cleaning</option>
                </select>
            </div>

            <div class="col-md-6 col-xl-3">
                <label class="form-label">Sort by</label>
                <select class="form-select">
                    <option selected>Newest</option>
                    <option>Price: Low to High</option>
                    <option>Price: High to Low</option>
                    <option>Top Rated</option>
                </select>
            </div>

            <div class="col-md-6 col-xl-3">
                <label class="form-label">View</label>
                <div class="d-grid">
                    <button class="btn btn-outline-secondary" type="button">12 results found</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    @for (int i = 1; i <= 9; i++)
    {
        @await Html.PartialAsync("_ServiceCard", i)
    }
</div>

<nav class="mt-4" aria-label="Services pagination">
    <ul class="pagination justify-content-center">
        <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
        <li class="page-item active"><a class="page-link" href="#">1</a></li>
        <li class="page-item"><a class="page-link" href="#">2</a></li>
        <li class="page-item"><a class="page-link" href="#">3</a></li>
        <li class="page-item"><a class="page-link" href="#">Next</a></li>
    </ul>
</nav>