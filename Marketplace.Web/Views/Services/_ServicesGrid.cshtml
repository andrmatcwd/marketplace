@model Marketplace.Web.Models.Services.ServicesPageViewModel

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-6 col-xl-4">
                <label class="form-label">Sort by</label>
                <select id="servicesSortBy" class="form-select">
                    <option value="newest" selected="@(Model.Filters.SortBy == "newest")">Newest</option>
                    <option value="price_asc" selected="@(Model.Filters.SortBy == "price_asc")">Price: Low to High</option>
                    <option value="price_desc" selected="@(Model.Filters.SortBy == "price_desc")">Price: High to Low</option>
                    <option value="rating_desc" selected="@(Model.Filters.SortBy == "rating_desc")">Top Rated</option>
                    <option value="title_asc" selected="@(Model.Filters.SortBy == "title_asc")">Title A-Z</option>
                </select>
            </div>

            <div class="col-md-6 col-xl-4">
                <label class="form-label">Results</label>
                <div class="form-control bg-body-tertiary">@Model.Results.TotalItems services found</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    @if (Model.Results.Items.Count == 0)
    {
        <div class="col-12">
            <div class="alert alert-light border mb-0">No services found.</div>
        </div>
    }
    else
    {
        @foreach (var item in Model.Results.Items)
        {
            @await Html.PartialAsync("_ServiceCard", item)
        }
    }
</div>

@if (Model.Results.TotalPages > 1)
{
    <nav class="mt-4" aria-label="Services pagination">
        <ul class="pagination justify-content-center flex-wrap">
            @for (var i = 1; i <= Model.Results.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Results.Page ? "active" : null)">
                    <a href="#"
                       class="page-link services-page-link"
                       data-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}