@model Marketplace.Web.Models.Services.ServiceItemViewModel
@using Marketplace.Web.Options
@using Microsoft.Extensions.Options
@inject IOptions<GoogleMapsOptions> GoogleMapsOptions

@{
    ViewData["Title"] = Model.Title;
    var apiKey = GoogleMapsOptions.Value.ApiKey;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/service-details.css" asp-append-version="true" />
}

<div class="container py-4 service-details-page">
    <div class="row g-4">

        <!-- Image -->
        <div class="col-lg-6">
            <div class="service-gallery">
                <!-- Main image -->
                <div class="service-gallery-main">
                    <img id="mainServiceImage"
                        src="@(Model.ImageUrls.FirstOrDefault() ?? Model.ImageUrl)"
                        alt="@Model.Title" />
                </div>

                <!-- Thumbnails -->
                @if (Model.ImageUrls != null && Model.ImageUrls.Count > 1)
                {
                    <div class="service-gallery-thumbs">
                        @foreach (var img in Model.ImageUrls)
                        {
                            <img src="@img"
                                class="gallery-thumb"
                                onclick="setMainImage(this)" />
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Info -->
        <div class="col-lg-6">

            <div class="mb-3">
                <span class="badge text-bg-light border text-capitalize">@Model.Category</span>
            </div>

            <h1 class="mb-3">@Model.Title</h1>

            <div class="mb-3 text-muted">
                ⭐ @Model.Rating.ToString("0.0") • @Model.City
            </div>

            <div class="mb-4">
                <h3 class="fw-bold">@Model.Price @Model.Currency</h3>
            </div>

            <div class="mb-4">
                <strong>Type:</strong>
                @(Model.IsOnline ? "Online" : "")
                @(Model.IsOnline && Model.IsOffline ? " / " : "")
                @(Model.IsOffline ? "Offline" : "")
            </div>

            <div class="mb-4">
                <p>@Model.Description</p>
            </div>

            <div class="d-grid gap-2">
                <button class="btn btn-primary btn-lg">Contact provider</button>
                <button class="btn btn-outline-secondary">Save</button>
            </div>
        </div>
    </div>

    <!-- Location -->
    @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="mb-3">Location</h5>

                        <div id="serviceMap"
                             class="service-map"
                             data-lat="@Model.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                             data-lng="@Model.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                             data-title="@Model.Title"
                             data-address="@Model.AddressLine">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

        <!-- Reviews -->
    <section class="reviews-section mt-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
                    <div>
                        <h4 class="mb-1">Reviews</h4>
                        <p class="text-muted mb-0">See what customers say about this service.</p>
                    </div>

                    <button type="button" class="btn btn-primary">
                        Write a review
                    </button>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-lg-4">
                        <div class="reviews-summary text-center text-lg-start">
                            <div class="reviews-summary-score">4.8</div>
                            <div class="reviews-summary-stars mb-2">★★★★★</div>
                            <div class="text-muted">Based on 24 reviews</div>
                        </div>
                    </div>

                    <div class="col-lg-8">
                        <div class="reviews-breakdown">
                            <div class="review-bar-row">
                                <span class="review-bar-label">5 stars</span>
                                <div class="progress review-progress">
                                    <div class="progress-bar" style="width: 75%"></div>
                                </div>
                                <span class="review-bar-value">18</span>
                            </div>

                            <div class="review-bar-row">
                                <span class="review-bar-label">4 stars</span>
                                <div class="progress review-progress">
                                    <div class="progress-bar" style="width: 17%"></div>
                                </div>
                                <span class="review-bar-value">4</span>
                            </div>

                            <div class="review-bar-row">
                                <span class="review-bar-label">3 stars</span>
                                <div class="progress review-progress">
                                    <div class="progress-bar" style="width: 4%"></div>
                                </div>
                                <span class="review-bar-value">1</span>
                            </div>

                            <div class="review-bar-row">
                                <span class="review-bar-label">2 stars</span>
                                <div class="progress review-progress">
                                    <div class="progress-bar" style="width: 0%"></div>
                                </div>
                                <span class="review-bar-value">0</span>
                            </div>

                            <div class="review-bar-row">
                                <span class="review-bar-label">1 star</span>
                                <div class="progress review-progress">
                                    <div class="progress-bar" style="width: 4%"></div>
                                </div>
                                <span class="review-bar-value">1</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="reviews-list">
                    <article class="review-item">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                            <div>
                                <h6 class="mb-1">Emma Wilson</h6>
                                <div class="review-stars">★★★★★</div>
                            </div>
                            <span class="text-muted small">2 days ago</span>
                        </div>

                        <p class="mb-2">
                            Very professional and friendly service. Everything was done on time and the result was even better than expected.
                        </p>

                        <div class="text-muted small">Service: Hair Styling</div>
                    </article>

                    <article class="review-item">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                            <div>
                                <h6 class="mb-1">Olivia Brown</h6>
                                <div class="review-stars">★★★★☆</div>
                            </div>
                            <span class="text-muted small">1 week ago</span>
                        </div>

                        <p class="mb-2">
                            Good experience overall. Easy communication and nice result. I would book again.
                        </p>

                        <div class="text-muted small">Verified customer</div>
                    </article>

                    <article class="review-item">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                            <div>
                                <h6 class="mb-1">Sophia Taylor</h6>
                                <div class="review-stars">★★★★★</div>
                            </div>
                            <span class="text-muted small">2 weeks ago</span>
                        </div>

                        <p class="mb-0">
                            Excellent attention to detail. Highly recommended.
                        </p>
                    </article>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    @if (Model.Latitude.HasValue && Model.Longitude.HasValue)
    {
        <script src="~/js/pages/service-details.js" asp-append-version="true"></script>
        <script async
                src="https://maps.googleapis.com/maps/api/js?key=@apiKey&loading=async&callback=initServiceMap&libraries=marker">
        </script>
    }
}