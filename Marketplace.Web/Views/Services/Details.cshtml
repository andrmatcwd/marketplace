@model Marketplace.Web.Models.Services.ServiceItemViewModel

@{
    ViewData["Title"] = Model.Title;
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/service-details.css" asp-append-version="true" />
}

<div class="container py-4 service-details-page">
    <div class="row g-4">

        <!-- Image -->
        <div class="col-lg-6">
            <div class="service-details-image-wrapper">
                <img src="@Model.ImageUrl"
                    alt="@Model.Title"
                    class="service-details-image" />
            </div>
        </div>

        <!-- Info -->
        <div class="col-lg-6">
            <div class="mb-3">
                <span class="badge text-bg-light border text-capitalize">@Model.Category</span>
            </div>

            <h1 class="mb-3">@Model.Title</h1>

            <div class="mb-3 text-muted">
                ⭐ @Model.Rating.ToString("0.0") • @Model.City
            </div>

            <div class="mb-4">
                <h3 class="fw-bold">@Model.Price @Model.Currency</h3>
            </div>

            <div class="mb-4">
                <strong>Type:</strong>
                @(Model.IsOnline ? "Online" : "")
                @(Model.IsOnline && Model.IsOffline ? " / " : "")
                @(Model.IsOffline ? "Offline" : "")
            </div>

            <div class="mb-4">
                <p>@Model.Description</p>
            </div>

            <div class="d-grid gap-2">
                <button class="btn btn-primary btn-lg">Contact provider</button>
                <button class="btn btn-outline-secondary">Save</button>
            </div>
        </div>
    </div>
</div>