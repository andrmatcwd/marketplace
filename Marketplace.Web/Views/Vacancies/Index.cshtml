@model Marketplace.Web.Models.Vacancies.VacanciesPageVm

@{
    ViewData["Title"] = "Vacancies";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/filter-bar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/mobile-drawer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/pagination.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/vacancies.css" asp-append-version="true" />
}

<partial name="~/Views/Shared/Sections/_PageHero.cshtml" model="Model.Hero" />
<partial name="~/Views/Shared/Sections/_SeoIntro.cshtml" model="Model.SeoIntro" />

<section class="app-section bg-light">
    <div class="section-header-row">
        <h2 class="section-title">
            Vacancies
            @if (Model.TotalCount > 0)
            {
                <span class="section-meta">Found: @Model.TotalCount</span>
            }
        </h2>
        <button type="button" class="btn btn-app-outline d-lg-none" data-mobile-filter-open>
            Filters
        </button>
    </div>

    <div class="d-none d-lg-block">
        <partial name="~/Views/Shared/Sections/_VacanciesFilterBar.cshtml" model="Model.Filter" />
    </div>

    <partial name="~/Views/Shared/Sections/_VacanciesMobileFilterDrawer.cshtml" model="Model.Filter" />

    @if (Model.HasVacancies)
    {
        <div class="vacancy-list">
            @foreach (var vacancy in Model.Vacancies)
            {
                <partial name="~/Views/Shared/Vacancies/_VacancyCard.cshtml" model="vacancy" />
            }
        </div>

        @if (Model.Pagination is not null)
        {
            <div class="mt-4">
                <partial name="~/Views/Shared/Sections/_Pagination.cshtml" model="Model.Pagination" />
            </div>
        }
    }
    else
    {
        <div class="empty-state app-card">
            <p class="empty-state-text">No vacancies found matching your filters.</p>
            <a href="@Model.Filter.ResetUrl" class="btn btn-app-outline btn-sm">Clear filters</a>
        </div>
    }
</section>

@section Scripts {
    <script src="~/js/catalog-filters.js" asp-append-version="true"></script>
    <script src="~/js/mobile-filters.js" asp-append-version="true"></script>
}
