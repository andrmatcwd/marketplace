@using Marketplace.Modules.Blog.Application.BlogPosts.Dtos
@using Marketplace.Web.Models.Shared
@using Marketplace.Web.Utils
@model BlogPostDto

@{
    var culture = ViewData["Culture"] as string ?? CultureHelper.Current();
    var isUk = culture == "uk";
    var seoTop    = ViewData["SeoTop"]    as SeoIntroVm;
    var seoBottom = ViewData["SeoBottom"] as SeoBottomVm;

    var wordCount    = System.Text.RegularExpressions.Regex.Replace(Model.Content, "<[^>]*>", " ")
                           .Split(' ', StringSplitOptions.RemoveEmptyEntries).Length;
    var readMinutes  = Math.Max(1, wordCount / 200);
    var publishDate  = (Model.PublishedAtUtc ?? Model.CreatedAtUtc).ToString("dd MMMM yyyy");
    var publishShort = (Model.PublishedAtUtc ?? Model.CreatedAtUtc).ToString("dd.MM.yyyy");
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/blog.css" asp-append-version="true" />
}

<div class="bp-page">

    <!-- ═══ HERO ════════════════════════════════════════════ -->
    <header class="bp-hero">
        <div class="bp-hero__inner">

            <!-- Breadcrumb -->
            <nav class="bp-breadcrumb" aria-label="breadcrumb">
                <a href="/@culture" class="bp-breadcrumb__link">@(isUk ? "Головна" : "Главная")</a>
                <span class="bp-breadcrumb__sep" aria-hidden="true">›</span>
                <a href="/@culture/blog" class="bp-breadcrumb__link">@(isUk ? "Блог" : "Блог")</a>
                <span class="bp-breadcrumb__sep" aria-hidden="true">›</span>
                <span class="bp-breadcrumb__current">@Model.Title</span>
            </nav>

            <!-- Meta chips -->
            <div class="bp-hero__chips">
                <span class="bp-chip bp-chip--date">
                    <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <rect x="1" y="3" width="14" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M1 7h14" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M5 1v4M11 1v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    @publishDate
                </span>
                <span class="bp-chip bp-chip--time">
                    <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M8 4.5V8l2.5 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    @readMinutes @(isUk ? "хв" : "мин")
                </span>
            </div>

            <!-- Title -->
            <h1 class="bp-hero__title">@Model.Title</h1>

            <!-- Lead / excerpt -->
            <p class="bp-hero__lead">@Model.Excerpt</p>

        </div>
    </header>

    <!-- ═══ COVER IMAGE ═════════════════════════════════════ -->
    @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
    {
        <div class="bp-cover-wrap">
            <figure class="bp-cover">
                <img src="@Model.CoverImageUrl" alt="@Model.Title" loading="eager" />
            </figure>
        </div>
    }

    <!-- ═══ SEO TOP — "About this article" ══════════════════ -->
    @if (seoTop is not null && seoTop.HasContent)
    {
        <div class="bp-seo-top-wrap">
            <aside class="bp-seo-top">
                <div class="bp-seo-top__icon" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                        <circle cx="10" cy="10" r="9" stroke="currentColor" stroke-width="1.6"/>
                        <path d="M10 9v5M10 6.5v.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    </svg>
                </div>
                <div class="bp-seo-top__body">
                    @if (!string.IsNullOrWhiteSpace(seoTop.Title))
                    {
                        <h2 class="bp-seo-top__title">@seoTop.Title</h2>
                    }
                    @if (!string.IsNullOrWhiteSpace(seoTop.Text))
                    {
                        <p class="bp-seo-top__text">@seoTop.Text</p>
                    }
                </div>
            </aside>
        </div>
    }

    <!-- ═══ ARTICLE CONTENT ════════════════════════════════ -->
    <div class="bp-content-wrap">
        <article class="bp-content">
            @Html.Raw(Model.Content)
        </article>
    </div>

    <!-- ═══ ARTICLE FOOTER ═════════════════════════════════ -->
    <div class="bp-footer-wrap">
        <footer class="bp-footer">
            <a href="/@culture/blog" class="bp-footer__back">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                @(isUk ? "Усі статті" : "Все статьи")
            </a>
            <span class="bp-footer__date">
                @(isUk ? "Опубліковано" : "Опубликовано") @publishShort
            </span>
        </footer>
    </div>

    <!-- ═══ SEO BOTTOM ══════════════════════════════════════ -->
    @if (seoBottom is not null && seoBottom.HasContent)
    {
        <div class="bp-seo-bottom-wrap">
            <section class="bp-seo-bottom">
                <div class="bp-seo-bottom__deco" aria-hidden="true">✍</div>
                <div class="bp-seo-bottom__body">
                    @if (!string.IsNullOrWhiteSpace(seoBottom.Title))
                    {
                        <h2 class="bp-seo-bottom__title">@seoBottom.Title</h2>
                    }
                    @if (!string.IsNullOrWhiteSpace(seoBottom.Text))
                    {
                        <p class="bp-seo-bottom__text">@seoBottom.Text</p>
                    }
                    <div class="bp-seo-bottom__actions">
                        <a href="/@culture/blog" class="btn btn-app">
                            @(isUk ? "Читати блог" : "Читать блог")
                        </a>
                        <a href="/@culture/for-business" class="btn btn-app-outline">
                            @(isUk ? "Для бізнесу" : "Для бизнеса")
                        </a>
                    </div>
                </div>
            </section>
        </div>
    }

</div>
