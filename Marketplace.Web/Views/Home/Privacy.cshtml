@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5 privacy-page">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-9">
            <div class="card border-0 shadow-sm privacy-card">
                <div class="card-body p-4 p-md-5">
                    <div class="mb-5">
                        <h1 class="display-6 fw-bold mb-3">Privacy Policy</h1>
                        <p class="text-muted mb-2">
                            Effective date: @DateTime.UtcNow.ToString("MMMM dd, yyyy")
                        </p>
                        <p class="lead mb-0">
                            This Privacy Policy explains how Marketplace collects, uses, stores, and protects
                            personal information when you use our website, services, and related features.
                        </p>
                    </div>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">1. Introduction</h2>
                        <p>
                            We respect your privacy and are committed to protecting your personal data.
                            This policy describes what information we collect, why we collect it, how we use it,
                            and what rights you may have regarding your data.
                        </p>
                        <p class="mb-0">
                            By using Marketplace, you agree to the collection and use of information in accordance
                            with this Privacy Policy.
                        </p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">2. Information We Collect</h2>
                        <p>We may collect the following categories of information:</p>
                        <ul class="mb-0">
                            <li>Account information, such as your name, email address, and login credentials.</li>
                            <li>Profile information, such as phone number, city, photo, or other details you choose to provide.</li>
                            <li>Service and listing information, including descriptions, prices, categories, and uploaded images.</li>
                            <li>Communication data, such as messages, inquiries, reviews, and customer support requests.</li>
                            <li>Transaction-related information, where applicable.</li>
                            <li>Technical data, such as IP address, browser type, device information, and usage analytics.</li>
                            <li>Location-related information, if you provide an address or allow location-based functionality.</li>
                        </ul>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">3. How We Use Your Information</h2>
                        <p>We use your information to:</p>
                        <ul class="mb-0">
                            <li>Provide, operate, and improve the Marketplace platform.</li>
                            <li>Create and manage user accounts.</li>
                            <li>Display listings, profiles, and service information.</li>
                            <li>Process requests, bookings, or inquiries.</li>
                            <li>Communicate with users about updates, support, and service-related matters.</li>
                            <li>Enhance security, detect fraud, and prevent misuse of the platform.</li>
                            <li>Comply with legal obligations and enforce our terms.</li>
                        </ul>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">4. Legal Basis for Processing</h2>
                        <p>
                            Where applicable, we process personal data on the basis of one or more of the following:
                            your consent, performance of a contract, compliance with legal obligations, and our legitimate
                            interest in operating, protecting, and improving the platform.
                        </p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">5. Sharing of Information</h2>
                        <p>We may share information in the following situations:</p>
                        <ul class="mb-0">
                            <li>With other users, to the extent necessary to display profiles, listings, and reviews.</li>
                            <li>With service providers who help us host, maintain, analyze, or support the platform.</li>
                            <li>With payment, identity, communication, or map providers where relevant.</li>
                            <li>When required by law, regulation, court order, or lawful request from authorities.</li>
                            <li>To protect the rights, safety, and security of Marketplace, our users, or others.</li>
                            <li>In connection with a business transfer, merger, or acquisition.</li>
                        </ul>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">6. Cookies and Similar Technologies</h2>
                        <p>
                            We may use cookies and similar technologies to maintain sessions, remember preferences,
                            analyze traffic, improve performance, and enhance the user experience. You can manage
                            cookie preferences through your browser settings, but disabling certain cookies may affect
                            site functionality.
                        </p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">7. Data Retention</h2>
                        <p>
                            We retain personal data only for as long as necessary for the purposes described in this policy,
                            including to provide services, resolve disputes, enforce agreements, and comply with legal obligations.
                        </p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">8. Data Security</h2>
                        <p>
                            We take reasonable technical and organizational measures to protect personal data against
                            unauthorized access, loss, misuse, alteration, or disclosure. However, no method of transmission
                            over the internet or electronic storage is completely secure, and we cannot guarantee absolute security.
                        </p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">9. Your Rights</h2>
                        <p>Depending on your jurisdiction, you may have the right to:</p>
                        <ul class="mb-0">
                            <li>Access personal data we hold about you.</li>
                            <li>Request correction of inaccurate or incomplete information.</li>
                            <li>Request deletion of your personal data.</li>
                            <li>Object to or restrict certain processing activities.</li>
                            <li>Withdraw consent where processing is based on consent.</li>
                            <li>Request a copy of your data, where applicable.</li>
                        </ul>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">10. Third-Party Services</h2>
                        <p>
                            Marketplace may contain links to third-party websites or integrate third-party services,
                            such as payment systems, authentication providers, analytics tools, or mapping services.
                            We are not responsible for the privacy practices of third parties, and we encourage you
                            to review their privacy policies separately.
                        </p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">11. Children’s Privacy</h2>
                        <p>
                            Marketplace is not intended for children under the age required by applicable law to use
                            the platform independently. We do not knowingly collect personal information from children
                            in violation of applicable law.
                        </p>
                    </section>

                    <section class="mb-5">
                        <h2 class="h4 fw-semibold mb-3">12. Changes to This Policy</h2>
                        <p>
                            We may update this Privacy Policy from time to time. Any changes will be posted on this page
                            with an updated effective date. Continued use of the platform after such changes become effective
                            constitutes acceptance of the revised policy.
                        </p>
                    </section>

                    <section>
                        <h2 class="h4 fw-semibold mb-3">13. Contact Us</h2>
                        <p class="mb-2">
                            If you have questions about this Privacy Policy or the way your personal data is handled,
                            please contact us:
                        </p>
                        <ul class="list-unstyled mb-0">
                            <li><strong>Marketplace</strong></li>
                            <li>Email: privacy@yourdomain.com</li>
                            <li>Website: www.yourdomain.com</li>
                        </ul>
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>