@model Marketplace.Web.Models.Home.HomePageVm

@{
    ViewData["Title"] = Model.Hero.Title;
}

<section class="home-hero-page">
    <div class="home-hero-card">
        <div class="home-hero-content">
            <div class="home-hero-copy">
                <div class="home-hero-badge">Local services marketplace</div>

                <h1 class="home-hero-title">@Model.Hero.Title</h1>
                <p class="home-hero-subtitle">@Model.Hero.Subtitle</p>

                <ul class="home-hero-points">
                    <li>Search by service and city</li>
                    <li>Browse structured categories</li>
                    <li>Compare listings quickly</li>
                </ul>
            </div>

            <div class="home-search-panel app-card">
                <div class="home-search-panel-body">
                    <h2 class="home-search-title">Start your search</h2>
                    <p class="home-search-description">
                        Choose a city and search for the service you need.
                    </p>

                    <form method="get"
                          action="@Model.Hero.SearchActionUrl"
                          id="homeSearchForm"
                          class="home-search-form">
                        <div class="home-search-field">
                            <label for="homeSearchInput" class="filter-label">Service</label>
                            <input id="homeSearchInput"
                                   name="search"
                                   type="text"
                                   class="form-control app-input"
                                   placeholder="@Model.Hero.SearchPlaceholder" />
                        </div>

                        <div class="home-search-field">
                            <label for="homeCitySelect" class="filter-label">City</label>
                            <select id="homeCitySelect" name="city" class="form-select app-select">
                                <option value="">@Model.Hero.CityPlaceholder</option>
                                @foreach (var option in Model.CityOptions)
                                {
                                    <option value="@option.Value">@option.Text</option>
                                }
                            </select>
                        </div>

                        <div class="home-search-actions">
                            <button type="submit" class="btn btn-app">Search</button>
                            <button type="button" class="btn btn-app-outline" id="detectLocationBtn">
                                Detect my city
                            </button>
                        </div>

                        <div id="detectedCityMessage" class="home-detected-city" hidden></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 mb-3 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">How it works</h2>
            <p class="text-muted mb-0">Simple steps for customers and providers</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="how-card text-center h-100">
                    <div class="how-icon">1</div>
                    <h5 class="mt-3">Search services</h5>
                    <p class="text-muted mb-0">
                        Browse categories, use filters, and find the service that matches your needs.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="how-card text-center h-100">
                    <div class="how-icon">2</div>
                    <h5 class="mt-3">Compare providers</h5>
                    <p class="text-muted mb-0">
                        Check details, ratings, prices, and reviews before making a decision.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="how-card text-center h-100">
                    <div class="how-icon">3</div>
                    <h5 class="mt-3">Book with confidence</h5>
                    <p class="text-muted mb-0">
                        Contact the provider directly and arrange the service quickly and easily.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<div id="popular-cities" class="anchor-section">
    <partial name="~/Views/Shared/Sections/_CitiesSection.cshtml" model="Model.PopularCitiesSection" />
</div>

<div id="popular-categories" class="anchor-section">
    <partial name="~/Views/Shared/Sections/_CategoriesSection.cshtml" model="Model.PopularCategoriesSection" />
</div>

<section class="app-section">
    <partial name="~/Views/Shared/Sections/_SectionHeader.cshtml" model="Model.FeaturedListingsSection.Header" />
    <partial name="~/Views/Shared/Lists/_ListingsGrid.cshtml" model="Model.FeaturedListingsSection.Listings" />
</section>

<partial name="~/Views/Shared/Sections/_SeoIntro.cshtml" model="Model.SeoIntro" />

@section Scripts {
    <script src="~/js/pages/home.js" asp-append-version="true"></script>
}