@model IEnumerable<Marketplace.Web.Models.Services.ServiceItemViewModel>

@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home.css" asp-append-version="true" />
}

<section class="home-hero py-5 py-lg-6">
    <div class="container">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-6">
                <span class="home-badge">Trusted local marketplace</span>

                <h1 class="display-5 fw-bold mt-3 mb-3">
                    Find trusted services for everyday needs
                </h1>

                <p class="lead text-muted mb-4">
                    Discover verified professionals, compare offers, read reviews, and book the right service with confidence.
                </p>

                <form asp-controller="Services" asp-action="Index" method="get" class="home-search-card shadow-sm">
                    <div class="row g-2 align-items-center">
                        <div class="col-lg-7">
                            <input type="text"
                                   name="Search"
                                   class="form-control form-control-lg"
                                   placeholder="What service are you looking for?" />
                        </div>

                        <div class="col-lg-3">
                            <select name="Categories" class="form-select form-select-lg">
                                <option value="">All categories</option>
                                <option value="beauty">Beauty</option>
                                <option value="repair">Repair</option>
                                <option value="education">Education</option>
                                <option value="cleaning">Cleaning</option>
                            </select>
                        </div>

                        <div class="col-lg-2 d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                Search
                            </button>
                        </div>
                    </div>
                </form>

                <div class="home-hero-stats mt-4">
                    <div class="home-stat">
                        <div class="home-stat-value">1,000+</div>
                        <div class="home-stat-label">Services</div>
                    </div>
                    <div class="home-stat">
                        <div class="home-stat-value">500+</div>
                        <div class="home-stat-label">Providers</div>
                    </div>
                    <div class="home-stat">
                        <div class="home-stat-value">4.9</div>
                        <div class="home-stat-label">Average rating</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="home-hero-visual shadow-sm">
                    <div class="home-hero-visual-content">
                        <div class="home-visual-card">
                            <div class="home-visual-card-title">Top rated providers</div>
                            <div class="home-visual-card-text">Browse trusted experts with verified reviews.</div>
                        </div>

                        <div class="home-visual-card">
                            <div class="home-visual-card-title">Easy filtering</div>
                            <div class="home-visual-card-text">Find services by category, price, rating, and location.</div>
                        </div>

                        <div class="home-visual-card">
                            <div class="home-visual-card-title">Fast contact</div>
                            <div class="home-visual-card-text">Connect with providers and book in minutes.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="fw-bold mb-2">Popular categories</h2>
                <p class="text-muted mb-0">Explore the most востребувані service categories.</p>
            </div>

            <a asp-controller="Services" asp-action="Index" class="btn btn-outline-secondary d-none d-md-inline-flex">
                View all services
            </a>
        </div>

        <div class="row g-4">
            <div class="col-6 col-md-3">
                <a asp-controller="Services" asp-action="Index" asp-route-Categories="beauty" class="category-card">
                    <div class="category-icon">💇</div>
                    <div class="category-title">Beauty</div>
                    <div class="category-text">Hair, nails, makeup and more</div>
                </a>
            </div>

            <div class="col-6 col-md-3">
                <a asp-controller="Services" asp-action="Index" asp-route-Categories="repair" class="category-card">
                    <div class="category-icon">🔧</div>
                    <div class="category-title">Repair</div>
                    <div class="category-text">Home, device and equipment repair</div>
                </a>
            </div>

            <div class="col-6 col-md-3">
                <a asp-controller="Services" asp-action="Index" asp-route-Categories="education" class="category-card">
                    <div class="category-icon">📘</div>
                    <div class="category-title">Education</div>
                    <div class="category-text">Tutors, mentors and learning support</div>
                </a>
            </div>

            <div class="col-6 col-md-3">
                <a asp-controller="Services" asp-action="Index" asp-route-Categories="cleaning" class="category-card">
                    <div class="category-icon">🧼</div>
                    <div class="category-title">Cleaning</div>
                    <div class="category-text">Home and office cleaning services</div>
                </a>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="fw-bold mb-2">Featured services</h2>
                <p class="text-muted mb-0">Popular offers selected for your marketplace homepage.</p>
            </div>
        </div>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model.Take(6))
                {
                    <div class="col-sm-6 col-xl-4">
                        <div class="card h-100 border-0 shadow-sm home-service-card">
                            <div class="home-service-card-image-wrapper">
                                <img src="@item.ImageUrl"
                                     alt="@item.Title"
                                     class="home-service-card-image" />
                            </div>

                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="badge text-bg-light border text-capitalize">@item.Category</span>
                                    <span class="text-muted small">@item.Rating.ToString("0.0") ★</span>
                                </div>

                                <h5 class="card-title mb-2">@item.Title</h5>

                                <p class="card-text text-muted mb-3">
                                    @item.Description
                                </p>

                                <div class="mt-auto">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="fw-semibold fs-5">@item.Price @item.Currency</span>
                                        <span class="text-muted small">@item.City</span>
                                    </div>

                                    <a asp-controller="Services"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-primary w-100">
                                        View details
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-light border mb-0">
                        Featured services will appear here.
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">How it works</h2>
            <p class="text-muted mb-0">Simple steps for customers and providers</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="how-card text-center h-100">
                    <div class="how-icon">1</div>
                    <h5 class="mt-3">Search services</h5>
                    <p class="text-muted mb-0">
                        Browse categories, use filters, and find the service that matches your needs.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="how-card text-center h-100">
                    <div class="how-icon">2</div>
                    <h5 class="mt-3">Compare providers</h5>
                    <p class="text-muted mb-0">
                        Check details, ratings, prices, and reviews before making a decision.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="how-card text-center h-100">
                    <div class="how-icon">3</div>
                    <h5 class="mt-3">Book with confidence</h5>
                    <p class="text-muted mb-0">
                        Contact the provider directly and arrange the service quickly and easily.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="trust-card h-100">
                    <h5>Verified providers</h5>
                    <p class="text-muted mb-0">
                        Build trust with detailed profiles, ratings, and transparent service information.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="trust-card h-100">
                    <h5>Clear pricing</h5>
                    <p class="text-muted mb-0">
                        Compare pricing and service details before contacting a provider.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="trust-card h-100">
                    <h5>Convenient experience</h5>
                    <p class="text-muted mb-0">
                        Use one place to search, compare, and choose the best service for your needs.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="home-cta py-5">
    <div class="container">
        <div class="home-cta-box text-center">
            <h2 class="fw-bold mb-3">Ready to find the right service?</h2>
            <p class="text-muted mb-4">
                Explore the marketplace and connect with trusted professionals today.
            </p>

            <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
                <a asp-controller="Services" asp-action="Index" class="btn btn-primary btn-lg">
                    Browse services
                </a>

                <a asp-controller="Home" asp-action="Privacy" class="btn btn-outline-secondary btn-lg">
                    Learn more
                </a>
            </div>
        </div>
    </div>
</section>