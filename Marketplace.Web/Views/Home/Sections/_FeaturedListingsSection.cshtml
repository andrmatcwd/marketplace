@model IEnumerable<Marketplace.Web.Models.Listings.ListingItemViewModel>
    
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="fw-bold mb-2">Featured services</h2>
                <p class="text-muted mb-0">Popular offers selected for your marketplace homepage.</p>
            </div>
        </div>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model.Take(6))
                {
                    <div class="col-sm-6 col-xl-4">
                        <div class="card h-100 border-0 shadow-sm home-listing-card">
                            <div class="home-listing-card-image-wrapper">
                                <img src="@item.ImageUrl"
                                     alt="@item.Title"
                                     class="home-listing-card-image" />
                            </div>

                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="badge text-bg-light border text-capitalize">@item.Category</span>
                                    <span class="text-muted small">@item.Rating.ToString("0.0") ★</span>
                                </div>

                                <h5 class="card-title mb-2">@item.Title</h5>

                                <p class="card-text text-muted mb-3">
                                    @item.Description
                                </p>

                                <div class="mt-auto">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="fw-semibold fs-5">@item.Price @item.Currency</span>
                                        <span class="text-muted small">@item.City</span>
                                    </div>

                                    <a asp-controller="Listings"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-primary w-100">
                                        View details
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-light border mb-0">
                        Featured services will appear here.
                    </div>
                </div>
            }
        </div>
    </div>
</section>