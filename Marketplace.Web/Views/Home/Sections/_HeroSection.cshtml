<section class="home-hero py-5 py-lg-6">
    <div class="container">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-6">
                <span class="home-badge">Trusted local marketplace</span>

                <h1 class="display-5 fw-bold mt-3 mb-3">
                    Find trusted services for everyday needs
                </h1>

                <p class="lead text-muted mb-4">
                    Discover verified professionals, compare offers, read reviews, and book the right service with confidence.
                </p>

                <form asp-controller="Services" asp-action="Index" method="get" class="home-search-card shadow-sm">
                    <div class="row g-2 align-items-center">
                        <div class="col-lg-7">
                            <input type="text"
                                   name="Search"
                                   class="form-control form-control-lg"
                                   placeholder="What service are you looking for?" />
                        </div>

                        <div class="col-lg-3">
                            <select name="Categories" class="form-select form-select-lg">
                                <option value="">All categories</option>
                                <option value="beauty">Beauty</option>
                                <option value="repair">Repair</option>
                                <option value="education">Education</option>
                                <option value="cleaning">Cleaning</option>
                            </select>
                        </div>

                        <div class="col-lg-2 d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                Search
                            </button>
                        </div>
                    </div>
                </form>

                <div class="home-hero-stats mt-4">
                    <div class="home-stat">
                        <div class="home-stat-value">1,000+</div>
                        <div class="home-stat-label">Services</div>
                    </div>
                    <div class="home-stat">
                        <div class="home-stat-value">500+</div>
                        <div class="home-stat-label">Providers</div>
                    </div>
                    <div class="home-stat">
                        <div class="home-stat-value">4.9</div>
                        <div class="home-stat-label">Average rating</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="home-hero-visual shadow-sm">
                    <div class="home-hero-visual-content">
                        <div class="home-visual-card">
                            <div class="home-visual-card-title">Top rated providers</div>
                            <div class="home-visual-card-text">Browse trusted experts with verified reviews.</div>
                        </div>

                        <div class="home-visual-card">
                            <div class="home-visual-card-title">Easy filtering</div>
                            <div class="home-visual-card-text">Find services by category, price, rating, and location.</div>
                        </div>

                        <div class="home-visual-card">
                            <div class="home-visual-card-title">Fast contact</div>
                            <div class="home-visual-card-text">Connect with providers and book in minutes.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>