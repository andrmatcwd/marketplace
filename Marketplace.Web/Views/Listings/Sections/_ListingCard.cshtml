@model Marketplace.Web.Models.Listings.ListingViewModel

<div class="col-sm-6 col-xl-4">
    <a asp-controller="Listings"
        asp-action="Details"
        asp-route-id="@Model.Id"
        class="text-decoration-none text-dark">
        <div class="card h-100 border-0 shadow-sm listing-card">
            <div class="listing-card-image-wrapper">
                <img src="@Model.ImageUrl"
                    alt="@Model.Title"
                    class="listing-card-image"
                    loading="lazy" />
            </div>

            <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="badge text-bg-light border text-capitalize">@Model.Category</span>
                    <span class="text-muted small">@Model.Rating.ToString("0.0") ★</span>
                </div>

                <h5 class="card-title mb-2">@Model.Title</h5>

                <p class="card-text text-muted mb-3">@Model.Description</p>

                <div class="mt-auto">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fw-semibold fs-5">@Model.Price @Model.Currency</span>
                        <span class="text-muted small">@Model.City</span>
                    </div>

                    <div class="small text-muted mb-3">
                        @(Model.IsOnline ? "Online" : "")@(Model.IsOnline && Model.IsOffline ? " / " : "")@(Model.IsOffline ? "Offline" : "")
                    </div>

                    <a asp-controller="Listings"
                        asp-action="Details"
                        asp-route-id="@Model.Id"
                        class="btn btn-primary w-100">
                            View details
                    </a>
                </div>
            </div>
        </div>
    </a>
</div>