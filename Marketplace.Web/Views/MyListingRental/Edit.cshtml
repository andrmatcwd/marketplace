@model Marketplace.Web.Areas.Admin.Models.Rentals.RentalFormVm
@using Marketplace.Modules.Listings.Application.Rentals.Dtos
@{
    ViewData["Title"] = "Rental";
    var rooms = ViewBag.RoomOptions as IReadOnlyList<RentalRoomAdminDto> ?? [];
    var rentalId = ViewBag.RentalId as int?;
}

<div class="container py-4" style="max-width:800px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Rental Info</h1>
        <a asp-controller="MyListings" asp-action="Edit" asp-route-id="@Model.ListingId" class="btn btn-outline-secondary btn-sm">← Back to Listing</a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body p-4">
            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ListingId" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label fw-semibold"></label>
                        <input asp-for="Price" class="form-control app-input" placeholder="e.g. $500/month" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Rooms" class="form-label fw-semibold"></label>
                        <input asp-for="Rooms" class="form-control app-input" placeholder="e.g. 2 rooms" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Area" class="form-label fw-semibold"></label>
                        <input asp-for="Area" class="form-control app-input" placeholder="e.g. 60 m²" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Floor" class="form-label fw-semibold"></label>
                        <input asp-for="Floor" class="form-control app-input" placeholder="e.g. 3rd floor" />
                    </div>
                    <div class="col-12">
                        <label asp-for="FeaturesText" class="form-label fw-semibold"></label>
                        <textarea asp-for="FeaturesText" class="form-control app-input" rows="4" placeholder="One feature per line"></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Save</button>
                    @if (rentalId.HasValue)
                    {
                        <button type="button" class="btn btn-outline-danger"
                                onclick="if(confirm('Remove rental info?')) document.getElementById('deleteRentalForm').submit()">
                            Remove Rental
                        </button>
                    }
                </div>
            </form>

            @if (rentalId.HasValue)
            {
                <form id="deleteRentalForm" asp-action="DeleteRental" asp-route-listingId="@Model.ListingId" method="post" class="d-none">
                    @Html.AntiForgeryToken()
                </form>
            }
        </div>
    </div>

    @if (rentalId.HasValue)
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 mb-0">Rooms / Options</h2>
            <a asp-action="CreateRoom" asp-route-rentalId="@rentalId" asp-route-listingId="@Model.ListingId" class="btn btn-primary btn-sm">+ Add Room</a>
        </div>

        @if (rooms.Any())
        {
            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Price</th>
                            <th>Area</th>
                            <th>Guests</th>
                            <th>Beds</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var room in rooms)
                        {
                            <tr>
                                <td>@room.Title</td>
                                <td>@room.Price</td>
                                <td>@room.Area</td>
                                <td>@room.Guests</td>
                                <td>@room.Beds</td>
                                <td class="text-end">
                                    <a asp-action="EditRoom" asp-route-id="@room.Id" asp-route-listingId="@Model.ListingId" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                    <form asp-action="DeleteRoom" asp-route-id="@room.Id" asp-route-listingId="@Model.ListingId" method="post" style="display:inline;" onsubmit="return confirm('Delete room?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No rooms added yet.</p>
        }
    }
</div>
