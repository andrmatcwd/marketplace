@model Marketplace.Web.Areas.Admin.Models.Rentals.RentalRoomFormVm
@{
    ViewData["Title"] = "Edit Room";
}

<div class="container py-4" style="max-width:700px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Edit Room</h1>
        <a asp-action="Edit" asp-route-listingId="@Model.ListingId" class="btn btn-outline-secondary btn-sm">← Back</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <form method="post" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="RentalId" />
                <input type="hidden" asp-for="ListingId" />

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" class="form-control app-input" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label fw-semibold"></label>
                        <input asp-for="Price" class="form-control app-input" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Area" class="form-label fw-semibold"></label>
                        <input asp-for="Area" class="form-control app-input" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Guests" class="form-label fw-semibold"></label>
                        <input asp-for="Guests" class="form-control app-input" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Beds" class="form-label fw-semibold"></label>
                        <input asp-for="Beds" class="form-control app-input" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control app-input" rows="3"></textarea>
                    </div>
                    <div class="col-12">
                        <label asp-for="AmenitiesText" class="form-label fw-semibold"></label>
                        <textarea asp-for="AmenitiesText" class="form-control app-input" rows="4" placeholder="One amenity per line"></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Edit" asp-route-listingId="@Model.ListingId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
