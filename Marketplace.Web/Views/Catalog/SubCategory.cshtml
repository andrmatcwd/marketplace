@model Marketplace.Web.Models.Catalog.SubCategoryPageVm

@{
    ViewData["Title"] = Model.Hero.Title;
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/filter-bar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/mobile-drawer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/pagination.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/listing-card.css" asp-append-version="true" />
}

<partial name="~/Views/Shared/Sections/_PageHero.cshtml" model="Model.Hero" />
<partial name="~/Views/Shared/Sections/_SeoIntro.cshtml" model="Model.SeoIntro" />
<partial name="~/Views/Shared/Sections/_ListingsSection.cshtml" model="Model.ListingsSection" />
<partial name="~/Views/Shared/Sections/_SeoBottom.cshtml" model="Model.SeoBottom" />

@section Scripts {
    <script src="~/js/catalog-filters.js" asp-append-version="true"></script>
    <script src="~/js/mobile-filters.js" asp-append-version="true"></script>
    <script src="~/js/search-autocomplete.js" asp-append-version="true"></script>
}