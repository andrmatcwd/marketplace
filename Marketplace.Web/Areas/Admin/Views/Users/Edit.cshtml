@model Marketplace.Web.Areas.Admin.Models.Users.UserEditVm
@using Marketplace.Modules.Users.Domain.Enums
@using Marketplace.Web.Authorization
@{
    ViewData["Title"] = "Edit User";
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Edit User</h2>
            <p class="admin-page-subtitle">@Model.DisplayName</p>
        </div>
        <div>
            <a asp-action="Index" class="admin-btn admin-btn--secondary">Back to Users</a>
        </div>
    </div>

    <div class="admin-card admin-card--form">
        <form method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="IdentityUserId" type="hidden" />
            <input asp-for="IsSelf" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="admin-form-grid">
                <div class="admin-form-group">
                    <label asp-for="DisplayName" class="admin-label"></label>
                    <input asp-for="DisplayName" class="admin-input" />
                    <span asp-validation-for="DisplayName" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Email" class="admin-label"></label>
                    <input asp-for="Email" class="admin-input" type="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Phone" class="admin-label"></label>
                    <input asp-for="Phone" class="admin-input" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Status" class="admin-label"></label>
                    <select asp-for="Status" class="admin-select">
                        @foreach (var s in Enum.GetValues<UserStatus>())
                        {
                            <option value="@((int)s)" selected="@(Model.Status == s)">@s</option>
                        }
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="admin-form-group" style="grid-column: 1 / -1;">
                    <label asp-for="Bio" class="admin-label"></label>
                    <textarea asp-for="Bio" class="admin-input" rows="3"></textarea>
                    <span asp-validation-for="Bio" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Role" class="admin-label">Role</label>
                    @if (Model.IsSelf)
                    {
                        <input type="text" value="@Model.Role" class="admin-input" disabled />
                        <input type="hidden" name="Role" value="@Model.Role" />
                        <span class="text-muted" style="font-size:.85em;">You cannot change your own role.</span>
                    }
                    else
                    {
                        <select asp-for="Role" class="admin-select">
                            @foreach (var role in AppRoles.All)
                            {
                                <option value="@role" selected="@(Model.Role == role)">@role</option>
                            }
                        </select>
                    }
                    <span asp-validation-for="Role" class="text-danger"></span>
                </div>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="admin-btn admin-btn--primary">Save</button>
                <a asp-action="Index" class="admin-btn admin-btn--secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
