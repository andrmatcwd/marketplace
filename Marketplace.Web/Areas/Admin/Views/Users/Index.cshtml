@model Marketplace.Web.Areas.Admin.Models.Users.UserIndexVm
@using Marketplace.Modules.Users.Domain.Enums
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Users";
    var statuses = ViewBag.Statuses as List<SelectListItem> ?? new();
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Users</h2>
            <p class="admin-page-subtitle">Registered users. Total: @Model.TotalCount</p>
        </div>
    </div>

    <div class="admin-card">
        <form method="get" class="admin-filterbar">
            <div class="admin-filterbar__group">
                <label for="search" class="admin-label">Search</label>
                <input id="search" name="search" value="@Model.Search" class="admin-input" placeholder="Name or email" />
            </div>

            <div class="admin-filterbar__group">
                <label for="status" class="admin-label">Status</label>
                <select id="status" name="status" class="admin-select">
                    <option value="">All statuses</option>
                    @foreach (var item in statuses)
                    {
                        <option value="@item.Value" selected="@(Model.Status?.ToString() == item.Value)">@item.Text</option>
                    }
                </select>
            </div>

            <div class="admin-filterbar__actions">
                <button type="submit" class="admin-btn admin-btn--primary">Apply</button>
                <a asp-action="Index" class="admin-btn admin-btn--secondary">Reset</a>
            </div>
        </form>
    </div>

    <div class="admin-card">
        @if (Model.Items.Any())
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th>Role</th>
                            <th>Registered</th>
                            <th class="admin-table__actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.DisplayName</td>
                                <td>@item.Email</td>
                                <td>
                                    @if (item.Status == UserStatus.Active)
                                    {
                                        <span class="admin-badge admin-badge--green">Active</span>
                                    }
                                    else if (item.Status == UserStatus.Suspended)
                                    {
                                        <span class="admin-badge admin-badge--yellow">Suspended</span>
                                    }
                                    else
                                    {
                                        <span class="admin-badge admin-badge--red">Deleted</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsAdmin)
                                    {
                                        <span class="admin-badge admin-badge--blue">Admin</span>
                                    }
                                    else
                                    {
                                        <span class="admin-badge admin-badge--gray">User</span>
                                    }
                                </td>
                                <td>@item.CreatedAtUtc.ToString("yyyy-MM-dd")</td>
                                <td class="admin-table__actions">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="admin-btn admin-btn--xs">Edit</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="admin-pagination">
                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        <a asp-action="Index"
                           asp-route-search="@Model.Search"
                           asp-route-status="@Model.Status"
                           asp-route-page="@p"
                           class="admin-pagination__item @(p == Model.Page ? "is-active" : "")">@p</a>
                    }
                </div>
            }
        }
        else
        {
            <partial name="~/Areas/Admin/Views/Shared/_AdminEmptyState.cshtml" model='"No users found."' />
        }
    </div>
</div>
