@model ContactRequestIndexVm

@{
    ViewData["Title"] = "Contact Requests";
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Contact Requests</h2>
            <p class="admin-page-subtitle">Заявки від клієнтів та бізнес-запити. Всього: @Model.TotalCount</p>
        </div>
    </div>

    <div class="admin-card">
        <form method="get" class="admin-filterbar">
            <div class="admin-filterbar__group">
                <label for="search" class="admin-label">Пошук</label>
                <input id="search" name="search" value="@Model.Search" class="admin-input" placeholder="Ім'я, телефон, компанія..." />
            </div>

            <div class="admin-filterbar__group">
                <label for="type" class="admin-label">Тип</label>
                <select id="type" name="type" class="admin-select">
                    <option value="">Усі типи</option>
                    <option value="@((int)ContactRequestType.ListingContact)" selected="@(Model.Type == ContactRequestType.ListingContact)">Контакт з listing</option>
                    <option value="@((int)ContactRequestType.BusinessInquiry)" selected="@(Model.Type == ContactRequestType.BusinessInquiry)">Бізнес-запит</option>
                </select>
            </div>

            <div class="admin-filterbar__group">
                <label for="status" class="admin-label">Статус</label>
                <select id="status" name="status" class="admin-select">
                    <option value="">Усі статуси</option>
                    @foreach (var s in Enum.GetValues<ContactRequestStatus>())
                    {
                        <option value="@((int)s)" selected="@(Model.Status == s)">@StatusLabel(s)</option>
                    }
                </select>
            </div>

            <div class="admin-filterbar__actions">
                <button type="submit" class="admin-btn admin-btn--primary">Застосувати</button>
                <a asp-action="Index" class="admin-btn admin-btn--secondary">Скинути</a>
            </div>
        </form>
    </div>

    <div class="admin-card">
        @if (Model.Items.Any())
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Тип</th>
                            <th>Статус</th>
                            <th>Ім'я</th>
                            <th>Телефон</th>
                            <th>Компанія / Listing</th>
                            <th>Дата</th>
                            <th class="admin-table__actions">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>
                                    @if (item.Type == ContactRequestType.BusinessInquiry)
                                    {
                                        <span class="admin-badge admin-badge--blue">Бізнес</span>
                                    }
                                    else
                                    {
                                        <span class="admin-badge admin-badge--gray">Listing</span>
                                    }
                                </td>
                                <td>
                                    <span class="admin-badge @StatusBadgeClass(item.Status)">@StatusLabel(item.Status)</span>
                                </td>
                                <td>@item.CustomerName</td>
                                <td>@item.CustomerPhone</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.CustomerCompany))
                                    {
                                        @item.CustomerCompany
                                    }
                                    else if (!string.IsNullOrEmpty(item.ListingTitle))
                                    {
                                        @item.ListingTitle
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>@item.CreatedAtUtc.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="admin-table__actions">
                                    <a asp-action="Detail" asp-route-id="@item.Id" class="admin-btn admin-btn--xs admin-btn--secondary">Деталі</a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline"
                                          onsubmit="return confirm('Видалити цю заявку?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="admin-btn admin-btn--xs admin-btn--danger">Видалити</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="admin-pagination">
                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        <a asp-action="Index"
                           asp-route-search="@Model.Search"
                           asp-route-type="@((int?)Model.Type)"
                           asp-route-status="@((int?)Model.Status)"
                           asp-route-page="@p"
                           class="admin-pagination__item @(p == Model.Page ? "is-active" : "")">@p</a>
                    }
                </div>
            }
        }
        else
        {
            <partial name="~/Areas/Admin/Views/Shared/_AdminEmptyState.cshtml" model='"Заявок ще немає або не знайдено за фільтром."' />
        }
    </div>
</div>

@functions {
    static string StatusLabel(ContactRequestStatus s) => s switch
    {
        ContactRequestStatus.New => "Новий",
        ContactRequestStatus.InProgress => "В роботі",
        ContactRequestStatus.Processed => "Оброблено",
        ContactRequestStatus.Rejected => "Відхилено",
        _ => s.ToString()
    };

    static string StatusBadgeClass(ContactRequestStatus s) => s switch
    {
        ContactRequestStatus.New => "admin-badge--yellow",
        ContactRequestStatus.InProgress => "admin-badge--blue",
        ContactRequestStatus.Processed => "admin-badge--green",
        ContactRequestStatus.Rejected => "admin-badge--red",
        _ => ""
    };
}
