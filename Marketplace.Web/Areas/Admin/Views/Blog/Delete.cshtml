@model BlogPostListItemVm

@{
    ViewData["Title"] = "Видалити пост";
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Видалити пост</h2>
            <p class="admin-page-subtitle">Цю дію неможливо скасувати.</p>
        </div>
    </div>

    <div class="admin-card admin-card--form" style="max-width: 560px;">
        <p style="margin-bottom: 20px;">Ти справді хочеш видалити цей пост?</p>

        <dl style="display:grid; grid-template-columns: auto 1fr; gap: 8px 16px; margin-bottom: 24px;">
            <dt class="admin-label">ID</dt>
            <dd style="margin:0;">@Model.Id</dd>

            <dt class="admin-label">Заголовок</dt>
            <dd style="margin:0; font-weight:600;">@Model.Title</dd>

            <dt class="admin-label">Slug</dt>
            <dd style="margin:0; color:var(--text-muted);">@Model.Slug</dd>

            <dt class="admin-label">Статус</dt>
            <dd style="margin:0;">
                @if (Model.IsPublished)
                {
                    <span class="admin-badge admin-badge--green">Опубліковано</span>
                }
                else
                {
                    <span class="admin-badge admin-badge--gray">Чернетка</span>
                }
            </dd>
        </dl>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="admin-form-actions">
                <button type="submit" class="admin-btn admin-btn--danger">Видалити</button>
                <a asp-action="Index" class="admin-btn admin-btn--secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>
