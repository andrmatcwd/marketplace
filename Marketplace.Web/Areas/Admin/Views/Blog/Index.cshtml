@model BlogPostIndexVm

@{
    ViewData["Title"] = "Blog";
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Blog</h2>
            <p class="admin-page-subtitle">Керування статтями блогу. Всього: @Model.TotalCount</p>
        </div>
        <div>
            <a asp-action="Create" class="admin-btn admin-btn--primary">Створити пост</a>
        </div>
    </div>

    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success">@successMsg</div>
    }

    <div class="admin-card">
        <form method="get" class="admin-filterbar">
            <div class="admin-filterbar__group">
                <label for="search" class="admin-label">Пошук</label>
                <input id="search" name="search" value="@Model.Search" class="admin-input" placeholder="Заголовок або slug" />
            </div>

            <div class="admin-filterbar__group">
                <label for="isPublished" class="admin-label">Статус</label>
                <select id="isPublished" name="isPublished" class="admin-select">
                    <option value="">Усі</option>
                    <option value="true" selected="@(Model.IsPublished == true)">Опубліковано</option>
                    <option value="false" selected="@(Model.IsPublished == false)">Чернетка</option>
                </select>
            </div>

            <div class="admin-filterbar__actions">
                <button type="submit" class="admin-btn admin-btn--primary">Застосувати</button>
                <a asp-action="Index" class="admin-btn admin-btn--secondary">Скинути</a>
            </div>
        </form>
    </div>

    <div class="admin-card">
        @if (Model.Items.Any())
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Заголовок</th>
                            <th>Slug</th>
                            <th>Статус</th>
                            <th>Дата створення</th>
                            <th>Оновлено</th>
                            <th class="admin-table__actions">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Title</td>
                                <td>@item.Slug</td>
                                <td>
                                    @if (item.IsPublished)
                                    {
                                        <span class="admin-badge admin-badge--green">Опубліковано</span>
                                    }
                                    else
                                    {
                                        <span class="admin-badge admin-badge--gray">Чернетка</span>
                                    }
                                </td>
                                <td>@item.CreatedAtUtc.ToString("dd.MM.yyyy")</td>
                                <td>@item.UpdatedAtUtc.ToString("dd.MM.yyyy")</td>
                                <td class="admin-table__actions">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="admin-btn admin-btn--xs admin-btn--secondary">Редагувати</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="admin-btn admin-btn--xs admin-btn--danger">Видалити</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="admin-pagination">
                    @for (var p = 1; p <= Model.TotalPages; p++)
                    {
                        <a asp-action="Index"
                           asp-route-search="@Model.Search"
                           asp-route-isPublished="@Model.IsPublished"
                           asp-route-page="@p"
                           class="admin-pagination__item @(p == Model.Page ? "is-active" : "")">@p</a>
                    }
                </div>
            }
        }
        else
        {
            <partial name="~/Areas/Admin/Views/Shared/_AdminEmptyState.cshtml" model='"Постів ще немає або не знайдено за фільтром."' />
        }
    </div>
</div>
