@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

    string navClass(string controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            ? "admin-nav__link is-active"
            : "admin-nav__link";
}

<div class="admin-sidebar__inner">
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="admin-logo">
        <span class="admin-logo__mark">A</span>
        <span class="admin-logo__text">Admin Panel</span>
    </a>

    <nav class="admin-nav">
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="@navClass("Dashboard")">Dashboard</a>
        <a asp-area="Admin" asp-controller="Cities" asp-action="Index" class="@navClass("Cities")">Cities</a>
        <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="@navClass("Categories")">Categories</a>
        <a asp-area="Admin" asp-controller="SubCategories" asp-action="Index" class="@navClass("SubCategories")">SubCategories</a>
        <a asp-area="Admin" asp-controller="Listings" asp-action="Index" class="@navClass("Listings")">Listings</a>
    </nav>
</div>