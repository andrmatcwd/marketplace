@model SubscriptionPlanFormVm
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Edit Subscription Plan";
    var tiers = ViewBag.Tiers as List<SelectListItem> ?? new();
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Edit Subscription Plan</h2>
            <p class="admin-page-subtitle">Update plan details.</p>
        </div>
    </div>

    <div class="admin-card admin-card--form">
        <form method="post" asp-route-id="@Model.Id">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="admin-form-grid">
                <div class="admin-form-group">
                    <label asp-for="Name" class="admin-label"></label>
                    <input asp-for="Name" class="admin-input" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="SubscriptionType" class="admin-label"></label>
                    <select asp-for="SubscriptionType" class="admin-select" asp-items="tiers"></select>
                    <span asp-validation-for="SubscriptionType" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="PriceUah" class="admin-label"></label>
                    <input asp-for="PriceUah" type="number" step="0.01" class="admin-input" />
                    <span asp-validation-for="PriceUah" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="DurationDays" class="admin-label"></label>
                    <input asp-for="DurationDays" type="number" class="admin-input" />
                    <span asp-validation-for="DurationDays" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="DisplayOrder" class="admin-label"></label>
                    <input asp-for="DisplayOrder" type="number" class="admin-input" />
                    <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label class="admin-label">
                        <input asp-for="IsActive" type="checkbox" /> @Html.DisplayNameFor(m => m.IsActive)
                    </label>
                </div>

                <div class="admin-form-group" style="grid-column: 1 / -1;">
                    <label asp-for="Description" class="admin-label"></label>
                    <textarea asp-for="Description" class="admin-textarea"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="admin-btn admin-btn--primary">Save</button>
                <a asp-action="Index" class="admin-btn admin-btn--secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
