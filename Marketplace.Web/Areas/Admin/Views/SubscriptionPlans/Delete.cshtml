@model SubscriptionPlanListItemVm
@{
    ViewData["Title"] = "Delete Subscription Plan";
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Delete Subscription Plan</h2>
            <p class="admin-page-subtitle">This action cannot be undone.</p>
        </div>
    </div>

    <div class="admin-card admin-card--form">
        <p>Are you sure you want to delete plan <strong>@Model.Name</strong> (@Model.SubscriptionType)?</p>

        <form method="post" asp-action="Delete" asp-route-id="@Model.Id">
            @Html.AntiForgeryToken()
            <div class="admin-form-actions">
                <button type="submit" class="admin-btn admin-btn--danger">Delete</button>
                <a asp-action="Index" class="admin-btn admin-btn--secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
