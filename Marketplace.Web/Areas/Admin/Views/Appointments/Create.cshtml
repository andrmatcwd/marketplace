@using Marketplace.Modules.Appointments.Domain.Enums
@using Marketplace.Web.Areas.Admin.Models.Appointments
@model AppointmentAdminFormVm

@{
    ViewData["Title"] = "Нова заявка";

    string StatusLabel(AppointmentStatus s) => s switch
    {
        AppointmentStatus.New       => "Нова",
        AppointmentStatus.InReview  => "На розгляді",
        AppointmentStatus.Converted => "Конвертовано",
        AppointmentStatus.Rejected  => "Відхилено",
        _                           => s.ToString()
    };
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Нова заявка</h2>
        </div>
        <div>
            <a asp-action="Index" class="admin-btn admin-btn--secondary">← Назад</a>
        </div>
    </div>

    <div class="admin-card admin-card--form" style="max-width:720px">
        <form method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <h3 class="admin-section-title" style="margin-bottom:16px">Інформація про бізнес</h3>

            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label asp-for="BusinessName" class="admin-label"></label>
                    <input asp-for="BusinessName" class="admin-input" placeholder="Назва компанії" />
                    <span asp-validation-for="BusinessName" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="CategoryName" class="admin-label"></label>
                    <input asp-for="CategoryName" class="admin-input" placeholder="Наприклад: IT-компанія" />
                    <span asp-validation-for="CategoryName" class="text-danger"></span>
                </div>
            </div>

            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label asp-for="CityName" class="admin-label"></label>
                    <input asp-for="CityName" class="admin-input" placeholder="Наприклад: Київ" />
                    <span asp-validation-for="CityName" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Address" class="admin-label"></label>
                    <input asp-for="Address" class="admin-input" placeholder="Вулиця, будинок" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
            </div>

            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label asp-for="Website" class="admin-label"></label>
                    <input asp-for="Website" class="admin-input" placeholder="https://example.com" />
                    <span asp-validation-for="Website" class="text-danger"></span>
                </div>
            </div>

            <div class="admin-form-group">
                <label asp-for="Description" class="admin-label"></label>
                <textarea asp-for="Description" class="admin-textarea" rows="4"
                          placeholder="Короткий опис бізнесу..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <h3 class="admin-section-title" style="margin:24px 0 16px">Контактна особа</h3>

            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label asp-for="ContactName" class="admin-label"></label>
                    <input asp-for="ContactName" class="admin-input" placeholder="Ім'я та прізвище" />
                    <span asp-validation-for="ContactName" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Phone" class="admin-label"></label>
                    <input asp-for="Phone" class="admin-input" placeholder="+380 XX XXX XX XX" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
            </div>

            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label asp-for="Email" class="admin-label"></label>
                    <input asp-for="Email" class="admin-input" placeholder="email@example.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            <h3 class="admin-section-title" style="margin:24px 0 16px">Адміністративні дані</h3>

            <div class="admin-form-row">
                <div class="admin-form-group">
                    <label asp-for="Status" class="admin-label"></label>
                    <select asp-for="Status" class="admin-select">
                        @foreach (AppointmentStatus s in Enum.GetValues<AppointmentStatus>())
                        {
                            <option value="@((int)s)" selected="@(Model.Status == s)">@StatusLabel(s)</option>
                        }
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            </div>

            <div class="admin-form-group">
                <label asp-for="AdminNotes" class="admin-label"></label>
                <textarea asp-for="AdminNotes" class="admin-textarea" rows="4"
                          placeholder="Внутрішні нотатки для команди..."></textarea>
                <span asp-validation-for="AdminNotes" class="text-danger"></span>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="admin-btn admin-btn--primary">Зберегти</button>
                <a asp-action="Index" class="admin-btn admin-btn--secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>
