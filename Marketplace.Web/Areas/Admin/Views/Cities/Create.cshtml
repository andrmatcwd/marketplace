@model CityFormVm
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Create City";
    var regions = ViewBag.Regions as List<SelectListItem> ?? new();
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Створити місто</h2>
            <p class="admin-page-subtitle">Додай нове місто у систему.</p>
        </div>
    </div>

    <div class="admin-card admin-card--form">
        <form method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="admin-form-grid">
                <div class="admin-form-group">
                    <label asp-for="RegionId" class="admin-label"></label>
                    <select asp-for="RegionId" class="admin-select">
                        <option value="">Оберіть регіон</option>
                        @foreach (var item in regions)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                    <span asp-validation-for="RegionId" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Name" class="admin-label"></label>
                    <input asp-for="Name" class="admin-input" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Slug" class="admin-label"></label>
                    <input asp-for="Slug" class="admin-input" />
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="admin-btn admin-btn--primary">Зберегти</button>
                <a asp-action="Index" class="admin-btn admin-btn--secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>