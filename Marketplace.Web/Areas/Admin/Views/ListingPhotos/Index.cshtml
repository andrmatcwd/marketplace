@using Marketplace.Modules.Listings.Application.Listings.Dtos
@model IReadOnlyList<ListingImageAdminDto>
@{
    ViewData["Title"] = "Фото лістингу";
    var listingId = (int)ViewBag.ListingId;
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/photos.css" asp-append-version="true" />
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Фото лістингу #@listingId</h2>
            <p class="admin-page-subtitle">Завантажте фото (JPG, PNG, WebP, до 10 MB). Перше фото стає основним.</p>
        </div>
        <div style="display:flex;gap:8px;">
            <a asp-area="Admin" asp-controller="Listings" asp-action="Edit" asp-route-id="@listingId" class="admin-btn admin-btn--secondary">← Назад до лістингу</a>
        </div>
    </div>

    @Html.AntiForgeryToken()

    <!-- Upload area -->
    <div class="admin-card photo-upload-zone" id="uploadZone" data-listing-id="@listingId" data-upload-url="@Url.Action("Upload", "ListingPhotos", new { area = "Admin" })">
        <div class="photo-upload-zone__inner">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p>Перетягніть фото сюди або <label for="photoFileInput" class="photo-upload-zone__link">оберіть файли</label></p>
            <p class="photo-upload-zone__hint">JPG, PNG, WebP, GIF — до 10 MB кожен</p>
        </div>
        <input type="file" id="photoFileInput" accept="image/*" multiple hidden />
    </div>

    <!-- Photo grid -->
    <div class="photo-grid" id="photoGrid"
         data-delete-url="@Url.Action("Delete", "ListingPhotos", new { area = "Admin" })"
         data-primary-url="@Url.Action("SetPrimary", "ListingPhotos", new { area = "Admin" })"
         data-listing-id="@listingId">

        @foreach (var img in Model)
        {
            <div class="photo-card" data-id="@img.Id" data-url="@img.Url">
                <div class="photo-card__img-wrap">
                    <img src="@img.Url" alt="@img.Alt" loading="lazy" />
                    @if (img.IsPrimary)
                    {
                        <span class="photo-card__badge">Основне</span>
                    }
                </div>
                <div class="photo-card__actions">
                    @if (!img.IsPrimary)
                    {
                        <button type="button" class="admin-btn admin-btn--xs admin-btn--secondary js-set-primary" title="Зробити основним">★ Основне</button>
                    }
                    <button type="button" class="admin-btn admin-btn--xs admin-btn--danger js-delete-photo" title="Видалити">Видалити</button>
                </div>
            </div>
        }
    </div>

    <div class="photo-upload-status" id="uploadStatus" hidden></div>
</div>

@section Scripts {
    <script src="~/js/admin/photo-manager.js" asp-append-version="true"></script>
}
