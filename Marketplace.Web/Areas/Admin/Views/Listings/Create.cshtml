@model ListingFormVm
@using Microsoft.AspNetCore.Mvc.Rendering
@using Marketplace.Modules.Listings.Domain.Enums.Listing
@using Marketplace.Modules.Listings.Domain.Enums.Subscription

@{
    ViewData["Title"] = "Create Listing";
    var categories = ViewBag.Categories as List<SelectListItem> ?? new();
    var subCategories = ViewBag.SubCategories as List<SelectListItem> ?? new();
    var cities = ViewBag.Cities as List<SelectListItem> ?? new();
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Створити listing</h2>
            <p class="admin-page-subtitle">Додай нове оголошення до каталогу.</p>
        </div>
    </div>

    <div class="admin-card admin-card--form">
        <form method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="admin-form-grid">
                <div class="admin-form-group" style="grid-column: 1 / -1;">
                    <label asp-for="Title" class="admin-label"></label>
                    <input asp-for="Title" class="admin-input" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Slug" class="admin-label"></label>
                    <input asp-for="Slug" class="admin-input" />
                    <span asp-validation-for="Slug" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="SellerId" class="admin-label"></label>
                    <input asp-for="SellerId" class="admin-input" />
                    <span asp-validation-for="SellerId" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="CategoryId" class="admin-label"></label>
                    <select asp-for="CategoryId" class="admin-select">
                        <option value="">Оберіть категорію</option>
                        @foreach (var item in categories)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="SubCategoryId" class="admin-label"></label>
                    <select asp-for="SubCategoryId" class="admin-select">
                        <option value="">Оберіть підкатегорію</option>
                        @foreach (var item in subCategories)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                    <span asp-validation-for="SubCategoryId" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="LocationId" class="admin-label"></label>
                    <select asp-for="LocationId" class="admin-select">
                        <option value="">Оберіть місто</option>
                        @foreach (var item in cities)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                    <span asp-validation-for="LocationId" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Price" class="admin-label"></label>
                    <input asp-for="Price" class="admin-input" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Currency" class="admin-label"></label>
                    <input asp-for="Currency" class="admin-input" />
                    <span asp-validation-for="Currency" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Status" class="admin-label"></label>
                    <select asp-for="Status" class="admin-select">
                        @foreach (var item in Enum.GetValues<ListingStatus>())
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="SubscriptionType" class="admin-label"></label>
                    <select asp-for="SubscriptionType" class="admin-select">
                        @foreach (var item in Enum.GetValues<SubscriptionType>())
                        {
                            <option value="@item">@item</option>
                        }
                    </select>
                    <span asp-validation-for="SubscriptionType" class="text-danger"></span>
                </div>

                <div class="admin-form-group" style="grid-column: 1 / -1;">
                    <label asp-for="AddressLine" class="admin-label"></label>
                    <input asp-for="AddressLine" class="admin-input" />
                    <span asp-validation-for="AddressLine" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Latitude" class="admin-label"></label>
                    <input asp-for="Latitude" class="admin-input" />
                    <span asp-validation-for="Latitude" class="text-danger"></span>
                </div>

                <div class="admin-form-group">
                    <label asp-for="Longitude" class="admin-label"></label>
                    <input asp-for="Longitude" class="admin-input" />
                    <span asp-validation-for="Longitude" class="text-danger"></span>
                </div>

                <div class="admin-form-group" style="grid-column: 1 / -1;">
                    <label asp-for="Description" class="admin-label"></label>
                    <textarea asp-for="Description" class="admin-textarea"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="admin-btn admin-btn--primary">Зберегти</button>
                <a asp-action="Index" class="admin-btn admin-btn--secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>