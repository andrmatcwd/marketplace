@model Marketplace.Web.Areas.Admin.Models.Listings.AdminListingsPageViewModel

@{
    var filter = Model.Filter;
}

<div class="card-footer bg-white d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div class="text-muted">
        Total: @Model.TotalItems
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination mb-0">
                <li class="page-item @(filter.Page <= 1 ? "disabled" : null)">
                    <a class="page-link"
                       asp-area="Admin"
                       asp-controller="Listings"
                       asp-action="Index"
                       asp-route-Search="@filter.Search"
                       asp-route-Category="@filter.Category"
                       asp-route-City="@filter.City"
                       asp-route-PriceFrom="@filter.PriceFrom"
                       asp-route-PriceTo="@filter.PriceTo"
                       asp-route-OnlineOnly="@filter.OnlineOnly"
                       asp-route-OfflineOnly="@filter.OfflineOnly"
                       asp-route-PageSize="@filter.PageSize"
                       asp-route-Page="@(filter.Page - 1)">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == filter.Page ? "active" : null)">
                        <a class="page-link"
                           asp-area="Admin"
                           asp-controller="Listings"
                           asp-action="Index"
                           asp-route-Search="@filter.Search"
                           asp-route-Category="@filter.Category"
                           asp-route-City="@filter.City"
                           asp-route-PriceFrom="@filter.PriceFrom"
                           asp-route-PriceTo="@filter.PriceTo"
                           asp-route-OnlineOnly="@filter.OnlineOnly"
                           asp-route-OfflineOnly="@filter.OfflineOnly"
                           asp-route-PageSize="@filter.PageSize"
                           asp-route-Page="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(filter.Page >= Model.TotalPages ? "disabled" : null)">
                    <a class="page-link"
                       asp-area="Admin"
                       asp-controller="Listings"
                       asp-action="Index"
                       asp-route-Search="@filter.Search"
                       asp-route-Category="@filter.Category"
                       asp-route-City="@filter.City"
                       asp-route-PriceFrom="@filter.PriceFrom"
                       asp-route-PriceTo="@filter.PriceTo"
                       asp-route-OnlineOnly="@filter.OnlineOnly"
                       asp-route-OfflineOnly="@filter.OfflineOnly"
                       asp-route-PageSize="@filter.PageSize"
                       asp-route-Page="@(filter.Page + 1)">
                        Next
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>