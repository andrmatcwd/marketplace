@model Marketplace.Web.Areas.Admin.Models.Services.AdminServicesPageViewModel

@{
    var filter = Model.Filter;
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input name="Search"
                       value="@filter.Search"
                       class="form-control"
                       placeholder="Title, description, city..." />
            </div>

            <div class="col-md-3">
                <label class="form-label">Category</label>
                <select name="Category" class="form-select">
                    <option value="">All categories</option>
                    @foreach (var category in filter.Categories)
                    {
                        <option value="@category.Value" selected="@(filter.Category == category.Value)">
                            @category.Label
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">City</label>
                <input name="City"
                       value="@filter.City"
                       class="form-control"
                       placeholder="Kyiv, Lviv..." />
            </div>

            <div class="col-md-2">
                <label class="form-label">Page size</label>
                <select name="PageSize" class="form-select">
                    <option value="5" selected="@(filter.PageSize == 5)">5</option>
                    <option value="10" selected="@(filter.PageSize == 10)">10</option>
                    <option value="20" selected="@(filter.PageSize == 20)">20</option>
                    <option value="50" selected="@(filter.PageSize == 50)">50</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Price from</label>
                <input name="PriceFrom"
                       value="@filter.PriceFrom"
                       class="form-control"
                       type="number"
                       step="0.01" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Price to</label>
                <input name="PriceTo"
                       value="@filter.PriceTo"
                       class="form-control"
                       type="number"
                       step="0.01" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           name="OnlineOnly"
                           value="true"
                           @(filter.OnlineOnly ? "checked" : null) />
                    <label class="form-check-label">Online only</label>
                </div>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           name="OfflineOnly"
                           value="true"
                           @(filter.OfflineOnly ? "checked" : null) />
                    <label class="form-check-label">Offline only</label>
                </div>
            </div>

            <input type="hidden" name="Page" value="1" />

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Apply filters</button>
                <a asp-area="Admin"
                   asp-controller="Services"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    Reset
                </a>
            </div>
        </form>
    </div>
</div>