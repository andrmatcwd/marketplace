@model Marketplace.Web.Models.Services.ServiceItemViewModel

@{
    ViewData["Title"] = "Edit Service";
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="h3 mb-1">Edit Service</h1>
        <p class="text-muted mb-0">Update service information.</p>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form method="post">
                @* @Html.AntiForgeryToken() *@
                <input asp-for="Id" type="hidden" />
                <partial name="Sections/_Form.cshtml" model="Model" />

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Update</button>
                    <a asp-area="Admin" asp-controller="Services" asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}