@using Marketplace.Modules.Listings.Application.Rentals.Dtos
@model RentalAdminDto
@{
    ViewData["Title"] = "Видалити rental";
    var listingId = (int)ViewBag.ListingId;
}

<div class="admin-page">
    <div class="admin-toolbar">
        <div>
            <h2 class="admin-page-title">Видалити rental</h2>
            <p class="admin-page-subtitle">Ви впевнені, що хочете видалити rental для оголошення #@listingId?</p>
        </div>
    </div>

    <div class="admin-card admin-card--form">
        <dl>
            <dt>Ціна</dt>
            <dd>@Model.Price</dd>
            <dt>Кімнати</dt>
            <dd>@Model.Rooms</dd>
            <dt>Площа</dt>
            <dd>@Model.Area</dd>
            <dt>Поверх</dt>
            <dd>@Model.Floor</dd>
        </dl>

        <form method="post" asp-action="DeleteRentalConfirmed">
            @Html.AntiForgeryToken()
            <input type="hidden" name="listingId" value="@listingId" />
            <div class="admin-form-actions">
                <button type="submit" class="admin-btn admin-btn--danger">Видалити</button>
                <a asp-action="Edit" asp-route-listingId="@listingId" class="admin-btn admin-btn--secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>
